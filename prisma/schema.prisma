/// Vault-sealed external credential store — the connector layer's single,
/// rotatable, encrypted-at-rest credential path (SC-28 / 3.13.16; IA-5; 3.5.10).
///
/// One row per (org, provider, user). `secretEnc` is the AES-256-GCM vault
/// envelope (`v2.<kid>.<iv>.<tag>.<ct>`) of a JSON secret bundle — refresh
/// tokens, access tokens, API keys, etc. — sealed via `src/lib/crypto/vault.ts`
/// and opened ONLY server-side at call time (never returned to a client/the
/// model). `meta` holds NON-secret hints (scopes, account email, expiry) safe to
/// read without unsealing. Reach this only through `src/lib/integrations/credentials.ts`.
///
/// `userId` is NULLABLE. Two row shapes coexist:
///   - PER-USER  (userId NOT NULL): the user's own grant, e.g. a personal Google
///     OAuth refresh token (read via getCredential / getUserCredential).
///   - ORG-LEVEL (userId NULL): an org-SHARED credential, e.g. a GitHub PAT or a
///     Nango/DocuSign service cred — strictly org-scoped (read via getOrgCredential).
///
/// Uniqueness is enforced by TWO PARTIAL unique indexes (defined in the
/// 20260606090000_org_level_connector_creds migration, NOT here — Prisma can't
/// model a `WHERE` on a unique index): `UNIQUE(org_id,provider,user_id) WHERE
/// user_id IS NOT NULL` (one cred per user) AND `UNIQUE(org_id,provider) WHERE
/// user_id IS NULL` (one org-level cred). Postgres treats NULLs as distinct, so a
/// plain `@@unique([orgId,provider,userId])` could NOT enforce a single org-level
/// row — hence the partial indexes. The `@@unique` is therefore DROPPED from the
/// model; `setCredential` (per-user) targets the per-user partial index via an
/// explicit upsert-where, and `setOrgCredential` uses findFirst-then-write because
/// Prisma `upsert` cannot target a partial-unique-with-null compound key.
model ConnectorCredential {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  provider  String
  userId    String?  @map("user_id") @db.Uuid
  secretEnc String   @map("secret_enc") // sealed via crypto/vault.ts — JSON bundle, never plaintext
  meta      Json     @default("{}") // NON-secret hints only (scopes/account/expiry); never the secret
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, provider])
  @@map("connector_credentials")
}

