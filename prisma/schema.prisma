}

/// Per-org RUNTIME CONFIG (design §8) — the GUI/API-tunable connector + agent surface,
/// kept SEPARATE from OrgSecuritySettings (auth posture) so the two concerns stay clean.
/// 1:1 with Organization. A MISSING row (no config) is the load-bearing default: it means
/// "all registered connectors enabled, breadth on, MCP off" — i.e. EXACTLY today's behavior.
/// getRuntimeConfig() normalizes null → that default; the tool-list gating treats a null
/// `enabledConnectors` as "all enabled" (an explicit list opts into a SUBSET).
///
/// GOV GUARDRAILS (applyGovGuardrails, enforced server-side on a flip-to-GOV AND on every
/// tenant-admin PATCH): a GOV org has breadthEnabled=false + mcpEnabled=false and may NOT
/// list a commercial-only connector in enabledConnectors. tenantClass itself lives on
/// Organization and is platform-owner-only — never settable here.
model OrgRuntimeConfig {
  id    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId String @unique @map("org_id") @db.Uuid

  /// Tri-state connector enablement, modeled Prisma-native (Prisma has no nullable scalar
  /// list, so a flag + array stand in for the plan's `enabledConnectors String[]?`):
  ///   - allowlistEnabled = false ⇒ "NULL" / ALL registered connectors enabled. This is the
  ///     DEFAULT and preserves CURRENT behavior. `enabledConnectors` is ignored here.
  ///   - allowlistEnabled = true  ⇒ only providers listed in `enabledConnectors` are enabled
  ///     (an explicit SUBSET; an empty array then means NONE enabled).
  /// getRuntimeConfig() collapses this to `enabledConnectors: string[] | null` so the rest of
  /// the system sees the clean `null = all` contract.
  allowlistEnabled  Boolean  @default(false) @map("allowlist_enabled")
  enabledConnectors String[] @default([]) @map("enabled_connectors")

  /// The Nango/commercial-breadth toggle. Default ON for commercial; forced OFF for GOV by
  /// the guardrails. When false, no commercial-only (breadth) connector tool is offered or
  /// dispatched, even for a commercial tenant. (This is ADDITIVE on top of the v2.15 Nango
  /// gov-block — gov still never sees Nango regardless of this flag.)
  breadthEnabled Boolean @default(true) @map("breadth_enabled")

  /// External-MCP exposure. Dormant (default OFF); forced OFF for GOV by the guardrails.
  mcpEnabled Boolean @default(false) @map("mcp_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("org_runtime_config")
}

model OrgEntitlements {
  id    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId String @unique @map("org_id") @db.Uuid

  /// Tri-state MODULE enablement, mirroring OrgRuntimeConfig's connector allowlist
  /// (Prisma has no nullable scalar list, so a flag + array stand in):
  ///   moduleAllowlistEnabled = false ⇒ ALL modules enabled. This is the DEFAULT and
  ///     preserves CURRENT behavior; enabledModules is ignored. The absence of a whole
  ///     row collapses to this too (see getEntitlements()).
  ///   moduleAllowlistEnabled = true  ⇒ only the keys in enabledModules are enabled (a
  ///     SUBSET; [] then = none). The FIXED modules (overview, settings) are always on.
  moduleAllowlistEnabled Boolean  @default(false) @map("module_allowlist_enabled")
  enabledModules         String[] @default([]) @map("enabled_modules")

  /// Same tri-state for industry SECTORS (e.g. "aec"). false ⇒ all sectors; true ⇒ the
  /// subset in enabledSectors. Pontis tenants default to the AEC sector only.
  sectorAllowlistEnabled Boolean  @default(false) @map("sector_allowlist_enabled")
  enabledSectors         String[] @default([]) @map("enabled_sectors")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("org_entitlements")
}

/// AGENT POLICY (design D9/§8) — the MIDDLE gate of `RBAC ∩ AgentPolicy ∩ Classification`
/// (narrowest wins). A per-org (1:1) tenant-admin-managed authorization on what the AI agent
/// may do PER TOOL CALL, enforced in the agent loop BEFORE executeTool (after handle-resolve,
/// before the write-path taint check). This is NOT the egress gate (which governs what the
/// model may SEE) — it governs which TOOLS/DOMAINS the agent may CALL and bounds their args.
///
/// THE LOAD-BEARING DEFAULT: the ABSENCE of a row ⇒ PERMISSIVE (all tools/domains, no arg
/// bounds) = EXACTLY today's behavior. getAgentPolicy() normalizes a missing row to that
/// default, so existing orgs are UNAFFECTED until an admin opts in. This is additive.
///
/// The 3 axes (D9 thin slice, extensible to the 10-axis model):
///   1. TOOLS  — allowedTools (tri-state, see below) + deniedTools (denylist always wins).
///   2. DOMAIN — deniedDomains: a tool whose coarse data-domain (TOOL_DOMAIN map) is listed
///               is refused (e.g. block all `finance`/`crm` tools).
///   3. ARGS   — allowedProjectIds (tri-state): a tool call carrying a `projectId` not in the
///               list is refused; maxResultLimit: a `limit`/`maxResults` arg above it is
///               CLAMPED DOWN (not refused) before the executor runs.
///
/// Tri-state (Prisma has no nullable scalar list, so a flag + array stand in for the spec's
/// `String[]?`):
///   - <flag>Set = false ⇒ "NULL" / NO restriction on that axis (the default). The array is
///     ignored. allowedTools: ALL tools allowed (subject to deniedTools/deniedDomains).
///     allowedProjectIds: ANY projectId allowed.
///   - <flag>Set = true  ⇒ only the listed values are allowed (a subset; [] then = NONE).
/// getAgentPolicy() collapses these to the clean `string[] | null` contract.
model AgentPolicy {
  id    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId String @unique @map("org_id") @db.Uuid

  /// AXIS 1 (tools) — tri-state ALLOWLIST. allowedToolsSet=false ⇒ all tools allowed (default);
  /// true ⇒ only `allowedTools` are allowed. `deniedTools` is an always-applied denylist (wins
  /// over the allowlist).
  allowedToolsSet Boolean  @default(false) @map("allowed_tools_set")
  allowedTools    String[] @default([]) @map("allowed_tools")
  deniedTools     String[] @default([]) @map("denied_tools")

  /// AXIS 2 (domain) — deniedDomains: coarse data-domains (work_items/finance/crm/…) the agent
  /// may NOT touch. A tool whose TOOL_DOMAIN is listed is refused. Empty ⇒ no domain blocked.
  deniedDomains String[] @default([]) @map("denied_domains")

  /// AXIS 3 (args) — maxResultLimit: a `limit`/`maxResults` arg above this is CLAMPED to it
  /// (null ⇒ no clamp). allowedProjectIds: tri-state ALLOWLIST of project scopes — a tool call
  /// carrying a `projectId` not in the list is refused (allowedProjectIdsSet=false ⇒ any allowed).
  maxResultLimit       Int?     @map("max_result_limit")
  allowedProjectIdsSet Boolean  @default(false) @map("allowed_project_ids_set")
  allowedProjectIds    String[] @default([]) @map("allowed_project_ids")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("agent_policy")
}

/// Cutover write-freeze flag (design spec §9.4). A row here means the org is in a short
/// write-frozen window during its per-tenant migration: the request proxy returns HTTP 405
/// on mutating verbs (POST/PUT/PATCH/DELETE) for that org while reads still pass. Keyed by
/// BOTH org_slug (dashboard URLs) and org_id (API URLs) so the proxy can match either form.
///
/// This is OPERATIONAL state, NOT tenant data — it is intentionally NOT org-FK'd (so it
/// survives independently of the migration) and is EXCLUDED from the cutover model graph
/// (scripts/cutover/lib/model-graph.ts EXCLUDED_GLOBAL_MODELS) — a frozen flag must never
/// be exported/imported as part of a tenant's data.
model FrozenOrg {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId    String   @unique @map("org_id") @db.Uuid
  orgSlug  String   @unique @map("org_slug")
  reason   String   @default("")
  frozenBy String?  @map("frozen_by")
  frozenAt DateTime @default(now()) @map("frozen_at")

  @@index([orgSlug])
  @@map("frozen_orgs")
}

