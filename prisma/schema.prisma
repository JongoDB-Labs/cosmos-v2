generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  extensions        = [pgcrypto]
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Plan {
  FREE
  TEAM
  BUSINESS
  ENTERPRISE
  GOV
}

enum TenantClass {
  GOV
  COMMERCIAL
}

enum OrgRole {
  OWNER
  ADMIN
  BILLING_ADMIN
  MEMBER
  VIEWER
  GUEST
}

enum ProjectRole {
  MANAGER
  LEAD
  MEMBER
  VIEWER
}

enum BoardType {
  KANBAN
  SCRUM
  BACKLOG
  TABLE
  CALENDAR
  TIMELINE
  OKR
  DASHBOARD
  PORTFOLIO
  RAID
  ROADMAP
  CFD
  PROGRAM
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum ColumnCategory {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

enum CycleKind {
  SPRINT
  PHASE
  MODULE
  RUN
  EVENT_DAY
  RELEASE
  ITERATION
}

enum Visibility {
  PRIVATE
  PROJECT
  ORG
}

enum IdpProtocol {
  OIDC // SAML added in the Keycloak/SAML translation-appliance follow-on
}

// ─────────────────────────────────────────────
// Phase 0: Foundation (Auth, Orgs, RBAC)
// ─────────────────────────────────────────────

model Organization {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  slug           String      @unique
  auth0OrgId     String?     @unique @map("auth0_org_id")
  plan           Plan        @default(FREE)
  tenantClass    TenantClass @default(GOV) @map("tenant_class")
  logoUrl        String?     @map("logo_url")
  themePrimary   String?     @map("theme_primary")
  themeMode      String?     @map("theme_mode") // "auto" | "dark" | "light"
  settings       Json        @default("{}")
  dbConnectionId String?     @map("db_connection_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  members                OrgMember[]
  invitations            Invitation[]
  apiKeys                ApiKey[]
  projects               Project[]
  integrations           Integration[]
  webhooks               Webhook[]
  complianceControls     ComplianceControl[]
  dataClassifications    DataClassification[]
  sessionRecords         SessionRecord[]
  ipAllowlists           IpAllowlist[]
  scimTokens             ScimToken[]
  securitySettings       OrgSecuritySettings?
  assistantConversations AssistantConversation[]
  chatChannels           ChatChannel[]
  savedReports           SavedReport[]
  projectTemplates       ProjectTemplate[]
  workItemTypes          WorkItemType[]
  cycles                 Cycle[]
  mcpServers             McpServer[]
  objectives             Objective[]
  feedbackItems          FeedbackItem[]
  homeWidgets            HomeWidget[]
  workRoles              WorkRole[]
  idpConnection          IdpConnection?
  connectorCredentials   ConnectorCredential[]

  @@map("organizations")
}

model User {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  auth0UserId        String?   @unique @map("auth0_user_id")
  googleId           String?   @unique @map("google_id")
  /// DEPRECATED — plaintext OAuth refresh token. The connector credential vault
  /// (ConnectorCredential, sealed) is now the source of truth for Google creds.
  /// This column only survives as a self-healing read-path fallback that
  /// opportunistically seals the token into ConnectorCredential and NULLs itself
  /// on first use (see getGoogleClientForUser). Once all rows have drained to
  /// NULL in prod, drop this column in a future cleanup migration. Do NOT write it.
  googleRefreshToken String?   @map("google_refresh_token")
  email              String
  displayName        String    @map("display_name")
  avatarUrl          String?   @map("avatar_url")
  lastActiveAt       DateTime? @map("last_active_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  memberships         OrgMember[]
  preferences         UserPreferences?
  sessions            Session[]
  cycleCapacities     CycleCapacity[]
  pushSubscriptions   PushSubscription[]
  homeWidgets         HomeWidget[]
  federatedIdentities FederatedIdentity[]

  @@map("users")
}

model Session {
  id        String   @id
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  // SSO assurance columns (additive; null/false for legacy + Google sessions).
  authMethod   String?  @map("auth_method") // e.g. "oidc"; null = local/Google
  idpConnId    String?  @map("idp_conn_id") @db.Uuid // the IdpConnection used, if SSO
  amr          String[] @default([]) // Authentication Methods References from the token
  mfaSatisfied Boolean  @default(false) @map("mfa_satisfied") // acr/amr met the org's floor

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model IdpConnection {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String      @map("org_id") @db.Uuid
  protocol         IdpProtocol @default(OIDC)
  issuerUrl        String      @map("issuer_url") // OIDC discovery base
  clientId         String      @map("client_id")
  clientSecretEnc  String      @map("client_secret_enc") // sealed via crypto/vault.ts
  scopes           String[]    @default(["openid", "email", "profile"])
  attributeMapping Json        @default("{}") @map("attribute_mapping") // {email,subject,groups} claim names
  roleMapping      Json        @default("{}") @map("role_mapping") // {"<group>":"ADMIN"} (capped at ADMIN)
  jitProvisioning  Boolean     @default(true) @map("jit_provisioning")
  defaultRole      OrgRole     @default(MEMBER) @map("default_role")
  requiredAcr      String?     @map("required_acr") // gov AAL floor (e.g. phishing-resistant)
  enabled          Boolean     @default(false)
  enforced         Boolean     @default(false) // gov: SSO-only, Google rejected
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  org        Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  identities FederatedIdentity[]

  @@unique([orgId]) // one IdP per org for this slice; multi-IdP-per-org is a later refinement
  @@map("idp_connections")
}

model FederatedIdentity {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  idpConnId String   @map("idp_conn_id") @db.Uuid
  subject   String // the IdP 'sub' — the stable match key
  createdAt DateTime @default(now()) @map("created_at")

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  idpConn IdpConnection @relation(fields: [idpConnId], references: [id], onDelete: Cascade)

  @@unique([idpConnId, subject]) // THE security-critical key — never match on email
  @@index([userId])
  @@map("federated_identities")
}

model AllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  addedBy   String?  @map("added_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("allowed_emails")
}

model OrgMember {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  role        OrgRole  @default(MEMBER)
  permissions BigInt   @default(0)
  abacRules   Json     @default("{}") @map("abac_rules")
  joinedAt    DateTime @default(now()) @map("joined_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectMembers ProjectMember[]
  workRoles      OrgMemberWorkRole[]

  @@unique([orgId, userId])
  @@map("org_members")
}

model Invitation {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  email     String
  role      OrgRole  @default(MEMBER)
  token     String   @unique @default(dbgenerated("gen_random_uuid()"))
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("invitations")
}

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  metadata  Json     @default("{}")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")
  // DB-generated monotonic sequence (GENERATED ALWAYS AS IDENTITY in the migration).
  // Optional + no Prisma @default so the client never writes it (DB fills it) and
  // `autoincrement()` doesn't emit SERIAL that would drift from the IDENTITY column.
  seq       BigInt?  @unique
  // AU-9 in-DB hash-chain (20260606070000). Filled by a BEFORE INSERT trigger exactly
  // like `seq` — nullable + no @default so the client never writes them. row_hash binds
  // prev_hash (the prior row's row_hash) + this row's framed columns; prev_hash is NULL
  // only for the genesis row. verify_audit_chain('audit_logs') walks + recomputes them.
  rowHash   Bytes?   @map("row_hash")
  prevHash  Bytes?   @map("prev_hash")

  // AU-9: org_id/user_id are recorded *data*, not live FKs — audit survives org/user
  // deletion (no cascade/SET NULL). Relations intentionally removed.

  @@index([orgId, createdAt])
  @@index([userId])
  @@map("audit_logs")
}

model EgressDecisionRow {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String   @map("conversation_id")
  turn           Int
  valueKind      String   @map("value_kind")
  toolName       String?  @map("tool_name")
  exposed        Boolean
  withheldCount  Int      @map("withheld_count")
  contentHash    String   @map("content_hash")
  decidedBy      String   @map("decided_by")
  tenantClass    String   @map("tenant_class")
  ceiling        String?
  createdAt      DateTime @default(now()) @map("created_at")
  // DB-generated monotonic sequence (GENERATED ALWAYS AS IDENTITY in the migration).
  seq            BigInt?  @unique
  // AU-9 in-DB hash-chain (20260606070000). Filled by a BEFORE INSERT trigger like `seq`;
  // nullable + no @default so the client never writes them.
  rowHash        Bytes?   @map("row_hash")
  prevHash       Bytes?   @map("prev_hash")

  @@index([conversationId, createdAt])
  @@map("egress_decisions")
}

/// Opaque-handle resolver store (AC-4 / 3.1.3 — controlled CUI-by-reference flow).
///
/// When the egress gate WITHHOLDS a CUI field from the model's view, we mint an
/// unguessable, CONVERSATION-SCOPED reference token (`h:<base64url(18 bytes)>`)
/// and hand the model the TOKEN — never the value. The CUI value itself is sealed
/// at rest here with the same vault (AES-256-GCM, v2.<kid> envelope) the connector
/// creds use, so a DB read never yields plaintext CUI. The model can then carry the
/// token into a later tool call; the agent loop RESOLVES it back to the real value
/// IN-BOUNDARY (before the executor runs) — so the model orchestrates CUI it never
/// reads.
///
/// SECURITY INVARIANTS (enforced in src/lib/ai/egress/handles.ts + tested):
///   - `token` is globally unique AND random (≥144 bits) — unforgeable.
///   - resolution is matched on (token) THEN verified `conversationId ===` — a
///     token minted in conversation A MUST NOT resolve in B (cross-conversation /
///     cross-tenant isolation; the conversation is the boundary, mirroring how
///     egress_decisions are correlated by conversationId, NOT by a cross-cutting FK).
///   - `valueEnc` is a sealed envelope, never plaintext; the token carries no CUI.
///
/// LIFETIME (AU-11 / bounded retention): handles are conversation-scoped and
/// short-lived. `createdAt` + the `@@index([conversationId])` (and the createdAt
/// index) support a TTL sweep — see scripts/dsop or the retention runbook; the
/// least-privilege story is a periodic DELETE of rows older than the conversation
/// window so sealed CUI does not accumulate. This is NOT an audit table (the AC-4
/// trail in egress_decisions records the mint/resolve EVENTS), so cosmos_app holds
/// full DML incl. DELETE for the cleanup sweep.
model EgressHandle {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String   @map("conversation_id")
  token          String   @unique
  /// vault-sealed CUI value (v2.<kid>.<iv>.<tag>.<ct>) — NEVER plaintext.
  valueEnc       String   @map("value_enc")
  /// the source entity type the handle was minted for (e.g. "work_item") — metadata, non-CUI.
  entityType     String   @map("entity_type")
  /// the source field name the handle stands in for (e.g. "description") — metadata, non-CUI.
  fieldName      String   @map("field_name")
  /// the DataClassification CEILING the value was WITHHELD under at MINT time (e.g. "CUI").
  /// C1 fix: resolving this handle forces the resolving turn's result to re-gate at ≥ this
  /// ceiling (max-by-rank) so a high-ceiling value can never be echoed back under a lower
  /// per-turn ceiling. Nullable (no ceiling ⇒ adds no floor; never LOWERS a gate). Non-CUI.
  ceiling        String?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([conversationId])
  @@index([createdAt])
  @@map("egress_handles")
}

model ApiKey {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String    @map("org_id") @db.Uuid
  name      String
  keyHash   String    @map("key_hash")
  prefix    String
  scopes    String[]
  expiresAt DateTime? @map("expires_at")
  lastUsed  DateTime? @map("last_used")
  createdAt DateTime  @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// ─────────────────────────────────────────────
// Phase 1: Projects, Boards, Work Items, Sprints
// ─────────────────────────────────────────────

model Project {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId             String   @map("org_id") @db.Uuid
  name              String
  key               String
  description       String?
  settings          Json     @default("{}")
  archived          Boolean  @default(false)
  projectTemplateId String?  @map("project_template_id") @db.Uuid
  enabledFeatures   String[] @default([]) @map("enabled_features")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  org             Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members         ProjectMember[]
  boards          Board[]
  cycles          Cycle[]
  objectives      Objective[]
  projectTemplate ProjectTemplate? @relation(fields: [projectTemplateId], references: [id])
  journalLines    JournalLine[]

  @@unique([orgId, key])
  @@map("projects")
}

model ProjectMember {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String      @map("project_id") @db.Uuid
  orgMemberId String      @map("org_member_id") @db.Uuid
  role        ProjectRole @default(MEMBER)

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  orgMember OrgMember @relation(fields: [orgMemberId], references: [id], onDelete: Cascade)

  @@unique([projectId, orgMemberId])
  @@map("project_members")
}

model Board {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String    @map("org_id") @db.Uuid
  projectId String    @map("project_id") @db.Uuid
  name      String
  type      BoardType
  config    Json      @default("{}")
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")

  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns          BoardColumn[]
  dashboardWidgets DashboardWidget[]

  @@map("boards")
}

model BoardColumn {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  boardId   String         @map("board_id") @db.Uuid
  name      String
  key       String
  color     String         @default("#7dd3fc")
  wipLimit  Int?           @map("wip_limit")
  sortOrder Int            @default(0) @map("sort_order")
  category  ColumnCategory @default(TODO)

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@unique([boardId, key])
  @@map("board_columns")
}

model WorkItem {
  id              String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String                      @map("org_id") @db.Uuid
  projectId       String                      @map("project_id") @db.Uuid
  title           String
  description     String                      @default("")
  columnKey       String                      @map("column_key")
  assigneeId      String?                     @map("assignee_id") @db.Uuid
  priority        Priority                    @default(MEDIUM)
  parentId        String?                     @map("parent_id") @db.Uuid
  ticketNumber    Int                         @map("ticket_number")
  storyPoints     Int?                        @map("story_points")
  sortOrder       Int                         @default(0) @map("sort_order")
  dueDate         DateTime?                   @map("due_date")
  startDate       DateTime?                   @map("start_date")
  completedAt     DateTime?                   @map("completed_at")
  columnEnteredAt DateTime?                   @map("column_entered_at")
  tags            String[]                    @default([])
  customFields    Json                        @default("{}") @map("custom_fields")
  createdById     String                      @map("created_by_id") @db.Uuid
  createdAt       DateTime                    @default(now()) @map("created_at")
  updatedAt       DateTime                    @updatedAt @map("updated_at")
  workItemTypeId  String                      @map("work_item_type_id") @db.Uuid
  cycleId         String?                     @map("cycle_id") @db.Uuid
  // RAG: legacy token-bag search vector — no longer written (kept for back-compat
  // until the column is dropped). Real semantic search uses `embedding` below.
  searchVector    Json?                       @map("search_vector")
  // RAG: pgvector embedding (384-dim, MiniLM). Prisma can't read/write `Unsupported`,
  // so it's populated via raw SQL (see src/lib/rag/embed.ts storeEmbedding) and queried
  // with a raw ANN <=> in src/lib/ai/executors/rag.ts.
  embedding       Unsupported("vector(384)")? @map("embedding")

  parent       WorkItem?    @relation("WorkItemHierarchy", fields: [parentId], references: [id])
  children     WorkItem[]   @relation("WorkItemHierarchy")
  workItemType WorkItemType @relation(fields: [workItemTypeId], references: [id])
  cycle        Cycle?       @relation(fields: [cycleId], references: [id])
  activities   Activity[]
  comments     Comment[]

  @@unique([orgId, projectId, ticketNumber])
  @@index([orgId, columnKey])
  @@index([orgId, assigneeId])
  @@map("work_items")
}

model Activity {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  workItemId String   @map("work_item_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  action     String
  field      String?
  oldValue   String?  @map("old_value")
  newValue   String?  @map("new_value")
  createdAt  DateTime @default(now()) @map("created_at")

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([orgId, workItemId])
  @@map("activities")
}

model Comment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  workItemId String   @map("work_item_id") @db.Uuid
  authorId   String   @map("author_id") @db.Uuid
  content    String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model PushSubscription {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  endpoint   String    @unique
  p256dh     String // base64url-encoded public key
  auth       String // base64url-encoded auth secret
  userAgent  String?   @map("user_agent")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ─────────────────────────────────────────────
// Phase 2: OKRs, CRM, Notes, Notifications
// ─────────────────────────────────────────────

model CrmContact {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  name         String
  // NOTE: canonical stage keys are UPPERCASE (LEAD/QUALIFIED/…), matching the
  // pipeline board's column keys. This DB-level default is legacy lowercase but
  // is unreachable in practice: every write goes through crmStageSchema
  // (src/lib/crm/stages.ts), which case-folds + validates and defaults an
  // omitted stage to "LEAD". A contact whose stage is not a canonical key would
  // be invisible on the board (counted only in stats). If a future migration
  // touches this table, flip the default to 'LEAD'.
  stage        String   @default("lead")
  value        String?
  dealValue    Decimal? @map("deal_value") @db.Decimal(19, 4)
  contactInfo  String?  @map("contact_info")
  ownerId      String?  @map("owner_id") @db.Uuid
  notes        String?
  customFields Json     @default("{}") @map("custom_fields")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([orgId, stage])
  @@map("crm_contacts")
}

model Note {
  id           String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String                      @map("org_id") @db.Uuid
  authorId     String                      @map("author_id") @db.Uuid
  title        String                      @default("")
  content      String                      @default("")
  visibility   Visibility                  @default(PRIVATE)
  // RAG: legacy token-bag search vector — no longer written (kept for back-compat
  // until the column is dropped). Real semantic search uses `embedding` below.
  searchVector Json?                       @map("search_vector")
  // RAG: pgvector embedding (384-dim, MiniLM). Populated via raw SQL (storeEmbedding)
  // and queried with a raw ANN <=> in src/lib/ai/executors/rag.ts.
  embedding    Unsupported("vector(384)")? @map("embedding")
  createdAt    DateTime                    @default(now()) @map("created_at")
  updatedAt    DateTime                    @updatedAt @map("updated_at")

  @@index([orgId, visibility])
  @@map("notes")
}

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String
  title     String
  body      String   @default("")
  refType   String?  @map("ref_type")
  refId     String?  @map("ref_id")
  read      Boolean  @default(false)
  url       String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, read])
  @@map("notifications")
}

model Partner {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  name         String
  type         String   @default("vendor")
  status       String   @default("active")
  website      String?
  contactName  String?  @map("contact_name")
  contactEmail String?  @map("contact_email")
  contactPhone String?  @map("contact_phone")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  contracts Contract[]

  @@index([orgId, status])
  @@map("partners")
}

model Product {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  name        String
  description String?
  sku         String?
  price       Decimal? @db.Decimal(19, 4)
  currency    String   @default("USD")
  status      String   @default("active")
  category    String?
  createdAt   DateTime @default(now()) @map("created_at")
