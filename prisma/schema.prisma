generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgcrypto]
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Plan {
  FREE
  TEAM
  BUSINESS
  ENTERPRISE
  GOV
}

enum TenantClass {
  GOV
  COMMERCIAL
}

enum OrgRole {
  OWNER
  ADMIN
  BILLING_ADMIN
  MEMBER
  VIEWER
  GUEST
}

enum ProjectRole {
  MANAGER
  LEAD
  MEMBER
  VIEWER
}

enum BoardType {
  KANBAN
  SCRUM
  BACKLOG
  TABLE
  CALENDAR
  TIMELINE
  OKR
  DASHBOARD
  PORTFOLIO
  RAID
  ROADMAP
  CFD
  PROGRAM
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum ColumnCategory {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

enum CycleKind {
  SPRINT
  PHASE
  MODULE
  RUN
  EVENT_DAY
  RELEASE
  ITERATION
}

enum Visibility {
  PRIVATE
  PROJECT
  ORG
}

// ─────────────────────────────────────────────
// Prod-parity enums (ported verbatim from prod for the per-tenant cutover —
// migration 20260607030000_prod_parity_reconciliation). DO NOT reorder values:
// the cutover does a structural copy and the enum label SET must match prod.
// ─────────────────────────────────────────────

// Directed work-item dependency vocabularies (Jira deps, VITL/POA&M chains).
enum LinkType {
  BLOCKS
  BLOCKED_BY
  RELATES
  DUPLICATES
  PREDECESSOR
  SUCCESSOR
  CLONES
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  VOID
}

enum EmploymentType {
  SALARY
  HOURLY
}

enum PayRunStatus {
  DRAFT
  POSTED
}

// Tool access ceiling for a chat bot. NONE = no cosmos tools (chat-only);
// READONLY = read/query/search tools only (never a mutation tool); FULL = the
// whole catalog. This is a CEILING applied on top of the invoking human's own
// per-tool permission scoping — a bot can never exceed the human who summoned
// it (see src/lib/chat/bot-runner.ts + tool-filter.ts).
enum ChatBotToolScope {
  NONE
  READONLY
  FULL
}

enum BankAccountProvider {
  MANUAL_IMPORT
  AKOYA
}

enum BankTxnStatus {
  IMPORTED
  CATEGORIZED
  MATCHED
  POSTED
  EXCLUDED
}

enum IdpProtocol {
  OIDC // SAML added in the Keycloak/SAML translation-appliance follow-on
}

// ─────────────────────────────────────────────
// Phase 0: Foundation (Auth, Orgs, RBAC)
// ─────────────────────────────────────────────

model Organization {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  slug           String      @unique
  auth0OrgId     String?     @unique @map("auth0_org_id")
  plan           Plan        @default(FREE)
  tenantClass    TenantClass @default(GOV) @map("tenant_class")
  logoUrl        String?     @map("logo_url")
  themePrimary   String?     @map("theme_primary")
  themeMode      String?     @map("theme_mode") // "auto" | "dark" | "light"
  // ── Phase 2: per-org white-label brand (all nullable; null = inherit the
  //    deployment/product default from getBrand()). Validated at the API
  //    boundary (defaultSkinId via isValidSkinId), not by a DB constraint.
  defaultSkinId  String?     @map("default_skin_id")
  brandName      String?     @map("brand_name")
  agentName      String?     @map("agent_name")
  tagline        String?
  wakeWord       String?     @map("wake_word")
  settings       Json        @default("{}")
  dbConnectionId String?     @map("db_connection_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  members                OrgMember[]
  invitations            Invitation[]
  apiKeys                ApiKey[]
  projects               Project[]
  integrations           Integration[]
  webhooks               Webhook[]
  complianceControls     ComplianceControl[]
  dataClassifications    DataClassification[]
  sessionRecords         SessionRecord[]
  ipAllowlists           IpAllowlist[]
  scimTokens             ScimToken[]
  securitySettings       OrgSecuritySettings?
  runtimeConfig          OrgRuntimeConfig?
  entitlements           OrgEntitlements?
  agentPolicy            AgentPolicy?
  assistantConversations AssistantConversation[]
  chatChannels           ChatChannel[]
  savedReports           SavedReport[]
  projectTemplates       ProjectTemplate[]
  workItemTypes          WorkItemType[]
  cycles                 Cycle[]
  mcpServers             McpServer[]
  objectives             Objective[]
  goals                  Goal[]
  milestones             Milestone[]
  kpis                   Kpi[]
  roadmapNodes           RoadmapNode[]
  feedbackItems          FeedbackItem[]
  homeWidgets            HomeWidget[]
  workRoles              WorkRole[]
  idpConnection          IdpConnection?
  connectorCredentials   ConnectorCredential[]
  // Prod-parity back-relations.
  documents              Document[]
  risks                  Risk[]
  deliverables           Deliverable[]
  blockers               Blocker[]
  changeRequests         ChangeRequest[]
  programBranches        ProgramBranch[]
  deliverableRevisions   DeliverableRevision[]
  chatBots               ChatBot[]
  aiSettings             OrgAiSettings?
  meetingTypeOptions     MeetingTypeOption[]

  @@map("organizations")
}

model User {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  auth0UserId       String?   @unique @map("auth0_user_id")
  googleId          String?   @unique @map("google_id")
  // The legacy plaintext google_refresh_token column has been swept into the sealed
  // ConnectorCredential store (scripts/dsop/seal-google-tokens.mjs) and DROPPED
  // (migration 20260606120000_drop_google_refresh_token). The sealed connector
  // credential vault is the SOLE source of truth for Google OAuth refresh tokens —
  // no plaintext secret column remains on User.
  email             String
  displayName       String    @map("display_name")
  avatarUrl         String?   @map("avatar_url")
  lastActiveAt      DateTime? @map("last_active_at")
  // ── Presence / availability (prod-parity; cosmetic, mostly NULL) ─────────────
  // Free-text custom status, an optional emoji, and a do-not-disturb expiry.
  customStatus      String?   @map("custom_status")
  customStatusEmoji String?   @map("custom_status_emoji")
  dndUntilAt        DateTime? @map("dnd_until_at")
  // Synthetic AI-bot accounts (chat bots) carry isBot=true so their messages are
  // authored by the bot rather than the invoking human and they appear in the
  // mention picker. Added for prod-parity (chat_bots feature + cutover round-trip
  // of prod's 12 bot users); additive, default false for all real users.
  isBot             Boolean   @default(false) @map("is_bot")
  // Local username/password auth (additive; null for Google/SSO-only users).
  // passwordHash is scrypt "salt:hash" hex; mfaSecret is the TOTP secret SEALED
  // via the vault; mfaRecoveryCodes are stored HASHED. None are ever returned
  // to the client.
  passwordHash      String?   @map("password_hash")
  passwordSetAt     DateTime? @map("password_set_at")
  mfaEnabled        Boolean   @default(false) @map("mfa_enabled")
  mfaSecret         String?   @map("mfa_secret")
  mfaRecoveryCodes  String[]  @default([]) @map("mfa_recovery_codes")
  mfaEnrolledAt     DateTime? @map("mfa_enrolled_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  memberships         OrgMember[]
  preferences         UserPreferences?
  sessions            Session[]
  cycleCapacities     CycleCapacity[]
  pushSubscriptions   PushSubscription[]
  homeWidgets         HomeWidget[]
  federatedIdentities FederatedIdentity[]
  aiSettings          UserAiSettings?
  // Prod-parity back-relations (chat bots + chat follows/alerts).
  chatBot             ChatBot?
  chatBotRuns         ChatBotRun[]
  chatThreadFollows   ChatThreadFollower[]
  chatAlertKeywords   ChatAlertKeyword[]
  apiKeys             ApiKey[]             @relation("ApiKeyCreatedBy")

  @@map("users")
}

model Session {
  id             String   @id
  userId         String   @map("user_id") @db.Uuid
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")
  // Sliding-window idle-timeout anchor: stamped (throttled) on each org-scoped
  // request and read by getAuthContext to enforce OrgSecuritySettings
  // .sessionTimeoutMins. Defaults to now() so pre-existing sessions start fresh.
  lastActivityAt DateTime @default(now()) @map("last_activity_at")
  // SSO assurance columns (additive; null/false for legacy + Google sessions).
  authMethod     String?  @map("auth_method") // e.g. "oidc"; null = local/Google
  idpConnId      String?  @map("idp_conn_id") @db.Uuid // the IdpConnection used, if SSO
  amr            String[] @default([]) // Authentication Methods References from the token
  mfaSatisfied   Boolean  @default(false) @map("mfa_satisfied") // acr/amr met the org's floor

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model IdpConnection {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String      @map("org_id") @db.Uuid
  protocol         IdpProtocol @default(OIDC)
  issuerUrl        String      @map("issuer_url") // OIDC discovery base
  clientId         String      @map("client_id")
  clientSecretEnc  String      @map("client_secret_enc") // sealed via crypto/vault.ts
  scopes           String[]    @default(["openid", "email", "profile"])
  attributeMapping Json        @default("{}") @map("attribute_mapping") // {email,subject,groups} claim names
  roleMapping      Json        @default("{}") @map("role_mapping") // {"<group>":"ADMIN"} (capped at ADMIN)
  jitProvisioning  Boolean     @default(true) @map("jit_provisioning")
  defaultRole      OrgRole     @default(MEMBER) @map("default_role")
  requiredAcr      String?     @map("required_acr") // gov AAL floor (e.g. phishing-resistant)
  enabled          Boolean     @default(false)
  enforced         Boolean     @default(false) // gov: SSO-only, Google rejected
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  org        Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  identities FederatedIdentity[]

  @@unique([orgId]) // one IdP per org for this slice; multi-IdP-per-org is a later refinement
  @@map("idp_connections")
}

model FederatedIdentity {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  idpConnId String   @map("idp_conn_id") @db.Uuid
  subject   String // the IdP 'sub' — the stable match key
  createdAt DateTime @default(now()) @map("created_at")

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  idpConn IdpConnection @relation(fields: [idpConnId], references: [id], onDelete: Cascade)

  @@unique([idpConnId, subject]) // THE security-critical key — never match on email
  @@index([userId])
  @@map("federated_identities")
}

model AllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  addedBy   String?  @map("added_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("allowed_emails")
}

/// Instance-level OAuth sign-in provider config (Microsoft, Google, …).
/// Replaces env-var secrets: a platform admin sets the OAuth app client
/// id/secret/tenant via the /admin UI and they're vault-sealed at rest
/// (secretEnc holds the JSON bundle). Read at request time by the sign-in flow.
model AuthProviderConfig {
  id        String   @id @default(cuid())
  provider  String   @unique // "microsoft" | "google"
  enabled   Boolean  @default(true)
  secretEnc String   @map("secret_enc") // vault-sealed {clientId, clientSecret, tenant?}
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("auth_provider_configs")
}

model OrgMember {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  role        OrgRole  @default(MEMBER)
  permissions BigInt   @default(0)
  abacRules   Json     @default("{}") @map("abac_rules")
  joinedAt    DateTime @default(now()) @map("joined_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectMembers ProjectMember[]
  workRoles      OrgMemberWorkRole[]

  @@unique([orgId, userId])
  @@map("org_members")
}

model Invitation {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  email       String
  role        OrgRole  @default(MEMBER)
  // Work-roles to assign when the invite is accepted (extra permission grants +
  // ABAC policies on top of the base org role). Validated against the actor's
  // ceiling at invite time; applied on consumption.
  workRoleIds String[] @default([]) @map("work_role_ids")
  token       String   @unique @default(dbgenerated("gen_random_uuid()"))
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("invitations")
}

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  metadata  Json     @default("{}")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")
  // DB-generated monotonic sequence (GENERATED ALWAYS AS IDENTITY in the migration).
  // Optional + no Prisma @default so the client never writes it (DB fills it) and
  // `autoincrement()` doesn't emit SERIAL that would drift from the IDENTITY column.
  seq       BigInt?  @unique
  // AU-9 in-DB hash-chain (20260606070000). Filled by a BEFORE INSERT trigger exactly
  // like `seq` — nullable + no @default so the client never writes them. row_hash binds
  // prev_hash (the prior row's row_hash) + this row's framed columns; prev_hash is NULL
  // only for the genesis row. verify_audit_chain('audit_logs') walks + recomputes them.
  rowHash   Bytes?   @map("row_hash")
  prevHash  Bytes?   @map("prev_hash")

  // AU-9: org_id/user_id are recorded *data*, not live FKs — audit survives org/user
  // deletion (no cascade/SET NULL). Relations intentionally removed.

  @@index([orgId, createdAt])
  @@index([userId])
  @@map("audit_logs")
}

model EgressDecisionRow {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String   @map("conversation_id")
  turn           Int
  valueKind      String   @map("value_kind")
  toolName       String?  @map("tool_name")
  exposed        Boolean
  withheldCount  Int      @map("withheld_count")
  contentHash    String   @map("content_hash")
  decidedBy      String   @map("decided_by")
  tenantClass    String   @map("tenant_class")
  ceiling        String?
  createdAt      DateTime @default(now()) @map("created_at")
  // DB-generated monotonic sequence (GENERATED ALWAYS AS IDENTITY in the migration).
  seq            BigInt?  @unique
  // AU-9 in-DB hash-chain (20260606070000). Filled by a BEFORE INSERT trigger like `seq`;
  // nullable + no @default so the client never writes them.
  rowHash        Bytes?   @map("row_hash")
  prevHash       Bytes?   @map("prev_hash")

  @@index([conversationId, createdAt])
  @@map("egress_decisions")
}

/// AU-11 retention-purge chain-checkpoint (20260606130000_audit_retention_checkpoint).
///
/// Records, at each sanctioned retention-purge boundary, the seq + row_hash of the LAST
/// PURGED row, HMAC-signed. The LATEST checkpoint per table (max checkpointSeq) is the
/// active anchor for verify_audit_chain() once the genesis row has been purged: the first
/// RETAINED row's prev_hash equals checkpointRowHash, so the chain stays verifiable across
/// the purge boundary. The HMAC sig is checked by scripts/dsop/verify-audit-chain.mjs (a SQL
/// function can't read the key from env); the SQL function anchors STRUCTURALLY at the hash.
///
/// Written ONLY by the owner-run scripts/dsop/purge-audit.mjs (one replica-mode txn).
/// Append-only for the app: cosmos_app holds SELECT, is REVOKEd INSERT/UPDATE/DELETE/TRUNCATE
/// (a forged checkpoint must be detectable, never silently editable by the running system).
model AuditChainCheckpoint {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 'audit_logs' | 'egress_decisions' (CHECK-constrained in the migration).
  tableName         String   @map("table_name")
  /// N = max(seq) of the purged rows; the boundary verify_audit_chain re-anchors above.
  checkpointSeq     BigInt   @map("checkpoint_seq")
  /// row_hash of the row AT seq N (the last purged row); equals the first retained row's prev_hash.
  checkpointRowHash Bytes    @map("checkpoint_row_hash")
  /// HMAC(tableName || checkpointSeq || checkpointRowHash) — forged-checkpoint detection.
  sig               Bytes
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([tableName, checkpointSeq(sort: Desc)])
  @@map("audit_chain_checkpoint")
}

/// Opaque-handle resolver store (AC-4 / 3.1.3 — controlled CUI-by-reference flow).
///
/// When the egress gate WITHHOLDS a CUI field from the model's view, we mint an
/// unguessable, CONVERSATION-SCOPED reference token (`h:<base64url(18 bytes)>`)
/// and hand the model the TOKEN — never the value. The CUI value itself is sealed
/// at rest here with the same vault (AES-256-GCM, v2.<kid> envelope) the connector
/// creds use, so a DB read never yields plaintext CUI. The model can then carry the
/// token into a later tool call; the agent loop RESOLVES it back to the real value
/// IN-BOUNDARY (before the executor runs) — so the model orchestrates CUI it never
/// reads.
///
/// SECURITY INVARIANTS (enforced in src/lib/ai/egress/handles.ts + tested):
///   - `token` is globally unique AND random (≥144 bits) — unforgeable.
///   - resolution is matched on (token) THEN verified `conversationId ===` — a
///     token minted in conversation A MUST NOT resolve in B (cross-conversation /
///     cross-tenant isolation; the conversation is the boundary, mirroring how
///     egress_decisions are correlated by conversationId, NOT by a cross-cutting FK).
///   - `valueEnc` is a sealed envelope, never plaintext; the token carries no CUI.
///
/// LIFETIME (AU-11 / bounded retention): handles are conversation-scoped and
/// short-lived. `createdAt` + the `@@index([conversationId])` (and the createdAt
/// index) support a TTL sweep — see scripts/dsop or the retention runbook; the
/// least-privilege story is a periodic DELETE of rows older than the conversation
/// window so sealed CUI does not accumulate. This is NOT an audit table (the AC-4
/// trail in egress_decisions records the mint/resolve EVENTS), so cosmos_app holds
/// full DML incl. DELETE for the cleanup sweep.
model EgressHandle {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String   @map("conversation_id")
  token          String   @unique
  /// vault-sealed CUI value (v2.<kid>.<iv>.<tag>.<ct>) — NEVER plaintext.
  valueEnc       String   @map("value_enc")
  /// the source entity type the handle was minted for (e.g. "work_item") — metadata, non-CUI.
  entityType     String   @map("entity_type")
  /// the source field name the handle stands in for (e.g. "description") — metadata, non-CUI.
  fieldName      String   @map("field_name")
  /// the DataClassification CEILING the value was WITHHELD under at MINT time (e.g. "CUI").
  /// C1 fix: resolving this handle forces the resolving turn's result to re-gate at ≥ this
  /// ceiling (max-by-rank) so a high-ceiling value can never be echoed back under a lower
  /// per-turn ceiling. Nullable (no ceiling ⇒ adds no floor; never LOWERS a gate). Non-CUI.
  ceiling        String?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([conversationId])
  @@index([createdAt])
  @@map("egress_handles")
}

model ApiKey {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  name        String
  keyHash     String    @map("key_hash")
  prefix      String
  scopes      String[]
  createdById String?   @map("created_by_id") @db.Uuid
  expiresAt   DateTime? @map("expires_at")
  lastUsed    DateTime? @map("last_used")
  createdAt   DateTime  @default(now()) @map("created_at")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy User?        @relation("ApiKeyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([orgId, prefix])
  @@index([createdById])
  @@map("api_keys")
}

// ─────────────────────────────────────────────
// Phase 1: Projects, Boards, Work Items, Sprints
// ─────────────────────────────────────────────

model Project {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId             String   @map("org_id") @db.Uuid
  name              String
  key               String
  description       String?
  settings          Json     @default("{}")
  archived          Boolean  @default(false)
  projectTemplateId String?  @map("project_template_id") @db.Uuid
  enabledFeatures   String[] @default([]) @map("enabled_features")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  org                 Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members             ProjectMember[]
  boards              Board[]
  cycles              Cycle[]
  objectives          Objective[]
  goals               Goal[]
  milestones          Milestone[]
  kpis                Kpi[]
  roadmapNodes        RoadmapNode[]
  projectTemplate     ProjectTemplate?     @relation(fields: [projectTemplateId], references: [id])
  journalLines        JournalLine[]
  dataClassifications DataClassification[]
  documents           Document[]
  risks               Risk[]
  deliverables        Deliverable[]
  blockers            Blocker[]
  changeRequests      ChangeRequest[]

  @@unique([orgId, key])
  @@map("projects")
}

model ProjectMember {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String      @map("project_id") @db.Uuid
  orgMemberId String      @map("org_member_id") @db.Uuid
  role        ProjectRole @default(MEMBER)
  allocationPercent Int? @map("allocation_percent") // % of time on this project
  onContract      Boolean   @default(true) @map("on_contract")
  cacStatus       String?   @map("cac_status")
  cacExpiry       DateTime? @map("cac_expiry")
  trainingStatus  String?   @map("training_status")
  accessStatus    String?   @map("access_status")
  ndaStatus       String?   @map("nda_status")
  complianceNotes String?   @map("compliance_notes")

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  orgMember OrgMember @relation(fields: [orgMemberId], references: [id], onDelete: Cascade)

  @@unique([projectId, orgMemberId])
  @@map("project_members")
}

model Board {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String    @map("org_id") @db.Uuid
  projectId String    @map("project_id") @db.Uuid
  name      String
  // URL slug, unique per project (prod-parity). Nullable so the additive migration
  // can land before any backfill populates existing rows (Postgres treats NULLs as
  // distinct, so the unique index coexists with not-yet-slugged rows).
  slug      String?
  type      BoardType
  config    Json      @default("{}")
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")

  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns          BoardColumn[]
  dashboardWidgets DashboardWidget[]

  @@unique([projectId, slug])
  @@map("boards")
}

model BoardColumn {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  boardId   String         @map("board_id") @db.Uuid
  name      String
  key       String
  color     String         @default("#7dd3fc")
  wipLimit  Int?           @map("wip_limit")
  sortOrder Int            @default(0) @map("sort_order")
  category  ColumnCategory @default(TODO)

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@unique([boardId, key])
  @@map("board_columns")
}

model WorkItem {
  id              String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String                      @map("org_id") @db.Uuid
  projectId       String                      @map("project_id") @db.Uuid
  title           String
  description     String                      @default("")
  columnKey       String                      @map("column_key")
  assigneeId      String?                     @map("assignee_id") @db.Uuid
  priority        Priority                    @default(MEDIUM)
  parentId        String?                     @map("parent_id") @db.Uuid
  ticketNumber    Int                         @map("ticket_number")
  storyPoints     Int?                        @map("story_points")
  sortOrder       Int                         @default(0) @map("sort_order")
  dueDate         DateTime?                   @map("due_date")
  startDate       DateTime?                   @map("start_date")
  completedAt     DateTime?                   @map("completed_at")
  columnEnteredAt DateTime?                   @map("column_entered_at")
  tags            String[]                    @default([])
  customFields    Json                        @default("{}") @map("custom_fields")
  createdById     String                      @map("created_by_id") @db.Uuid
  createdAt       DateTime                    @default(now()) @map("created_at")
  updatedAt       DateTime                    @updatedAt @map("updated_at")
  workItemTypeId  String                      @map("work_item_type_id") @db.Uuid
  cycleId         String?                     @map("cycle_id") @db.Uuid
  // RAG: legacy token-bag search vector — no longer written (kept for back-compat
  // until the column is dropped). Real semantic search uses `embedding` below.
  searchVector    Json?                       @map("search_vector")
  // RAG: pgvector embedding (384-dim, MiniLM). Prisma can't read/write `Unsupported`,
  // so it's populated via raw SQL (see src/lib/rag/embed.ts storeEmbedding) and queried
  // with a raw ANN <=> in src/lib/ai/executors/rag.ts.
  embedding       Unsupported("vector(384)")? @map("embedding")

  // ── Superset / import-provenance fields (prod-parity column reconciliation) ──
  // All nullable; carry imported-record provenance so a v1→v2 cutover loses no
  // data and future re-import stays lossless. Origin system, e.g. "jira" | "linear".
  externalSource    String? @map("external_source")
  // Stable internal id from the source system (used for idempotent re-import).
  externalId        String? @map("external_id")
  // Human-readable source key, e.g. "PROJ-123".
  externalKey       String? @map("external_key")
  // Original workflow status text from the source (before mapping to a column).
  sourceStatus      String? @map("source_status")
  // Original resolution text from the source (e.g. "Fixed", "Won't Do").
  resolution        String?
  // Verbatim original source row — true losslessness for unmapped columns.
  sourceRecord      Json?   @map("source_record")
  // Time tracking, stored in SECONDS to match Jira's worklog unit.
  originalEstimate  Int?    @map("original_estimate")
  remainingEstimate Int?    @map("remaining_estimate")
  timeSpent         Int?    @map("time_spent")

  parent        WorkItem?            @relation("WorkItemHierarchy", fields: [parentId], references: [id])
  children      WorkItem[]           @relation("WorkItemHierarchy")
  workItemType  WorkItemType         @relation(fields: [workItemTypeId], references: [id])
  cycle         Cycle?               @relation(fields: [cycleId], references: [id])
  activities    Activity[]
  comments      Comment[]
  // Prod-parity back-relations (dependency links + attachments).
  outgoingLinks WorkItemLink[]       @relation("WorkItemLinkSource")
  incomingLinks WorkItemLink[]       @relation("WorkItemLinkTarget")
  attachments   WorkItemAttachment[]

  @@unique([orgId, projectId, ticketNumber])
  // Idempotent re-import key (prod-parity): one imported record per source per org.
  @@unique([orgId, externalSource, externalId])
  @@index([orgId, columnKey])
  @@index([orgId, assigneeId])
  @@map("work_items")
}

