// A first-class AI bot scoped to an org (FULLY WIRED — drives bot-runner via the
// CUI-blind agent loop). Backed by a synthetic User (isBot=true) so its messages
// are authored by the bot. toolScope is a hard tool-ceiling; enabledMcp stays
// OFF for gov.
model ChatBot {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String           @map("org_id") @db.Uuid
  key          String
  displayName  String           @map("display_name")
  persona      String           @default("")
  model        String           @default("sonnet")
  toolScope    ChatBotToolScope @default(NONE) @map("tool_scope")
  enabledMcp   Boolean          @default(false) @map("enabled_mcp")
  scheduleCron String?          @map("schedule_cron")
  userId       String           @unique @map("user_id") @db.Uuid
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  org      Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  channels ChatBotChannel[]
  runs     ChatBotRun[]

  @@unique([orgId, key])
  @@index([orgId])
  @@map("chat_bots")
}

// Per-channel bot configuration (SCHEMA-ONLY in v2; empty in prod).
model ChatBotChannel {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  botId       String   @map("bot_id") @db.Uuid
  channelId   String   @map("channel_id") @db.Uuid
  autoRespond Boolean  @default(false) @map("auto_respond")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  bot     ChatBot     @relation(fields: [botId], references: [id], onDelete: Cascade)
  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([botId, channelId])
  @@index([channelId])
  @@map("chat_bot_channels")
}

// Audit trail of a single bot invocation (SCHEMA-ONLY in v2; empty in prod).
model ChatBotRun {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  botId             String   @map("bot_id") @db.Uuid
  messageId         String   @map("message_id") @db.Uuid
  triggeredByUserId String   @map("triggered_by_user_id") @db.Uuid
  status            String   @default("pending")
  createdAt         DateTime @default(now()) @map("created_at")

  bot         ChatBot     @relation(fields: [botId], references: [id], onDelete: Cascade)
  message     ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  triggeredBy User        @relation(fields: [triggeredByUserId], references: [id])

  @@index([botId, createdAt])
  @@index([messageId])
  @@map("chat_bot_runs")
}

