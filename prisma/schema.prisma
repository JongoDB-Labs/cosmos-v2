model BankTransaction {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String        @map("org_id") @db.Uuid
  bankAccountId    String        @map("bank_account_id") @db.Uuid
  externalId       String?       @map("external_id")
  fingerprint      String        @map("fingerprint")
  postedDate       DateTime      @map("posted_date") @db.Date
  amount           Decimal       @db.Decimal(19, 4)
  description      String        @default("")
  pending          Boolean       @default(false)
  status           BankTxnStatus @default(IMPORTED)
  matchedExpenseId String?       @map("matched_expense_id") @db.Uuid
  matchedRevenueId String?       @map("matched_revenue_id") @db.Uuid
  category         String?
  createdAt        DateTime      @default(now()) @map("created_at")

  account BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@unique([bankAccountId, externalId])
  @@unique([bankAccountId, fingerprint])
  @@index([orgId, bankAccountId, status])
  @@map("bank_transactions")
}

model BankRule {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId               String   @map("org_id") @db.Uuid
  name                String   @default("")
  descriptionContains String?  @map("description_contains")
  direction           String   @default("any")
  amountMin           Decimal? @map("amount_min") @db.Decimal(19, 4)
  amountMax           Decimal? @map("amount_max") @db.Decimal(19, 4)
  category            String
  priority            Int      @default(0)
  isActive            Boolean  @default(true) @map("is_active")
  createdById         String   @map("created_by_id") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([orgId, isActive, priority])
  @@map("bank_rules")
}

// ---------------------------------------------------------------------------
// Govcon program-management models (PM Dashboard) — the compliance/reporting
// layer the commercial schema lacks. Org-scoped, CUI-classified by default,
// keyed on a stable per-org code. See docs schema-mapping for the full mapping.
// ---------------------------------------------------------------------------

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskStatus {
  OPEN
  MONITORING
  MITIGATING
  MITIGATED
  CLOSED
  ESCALATED
}

enum DeliverableStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  IN_GOVT_REVIEW
  ACCEPTED
  REJECTED
  DRAFT_IN_PROGRESS
  INTERNAL_REVIEW
  ACCEPTED_WITH_COMMENTS
  REVISION_REQUIRED
  OVERDUE
}

enum BlockerType {
  INTERNAL
  EXTERNAL_GOVERNMENT
  EXTERNAL_VENDOR
  EXTERNAL_PROCUREMENT
  EXTERNAL_THIRD_PARTY
}

enum BlockerStatus {
  OPEN
  RESOLVED
  IN_PROGRESS
  ESCALATED
}

enum ChangeRequestStatus {
  SUBMITTED
  APPROVED
  REJECTED
  IMPLEMENTED
  UNDER_REVIEW
  WITHDRAWN
}

model Risk {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId          String              @map("org_id") @db.Uuid
  projectId      String              @map("project_id") @db.Uuid
  code           String
  title          String
  description    String?
  category       String?
  branch         String?
  likelihood     Int                 @default(1)
  impact         Int                 @default(1)
  score          Int                 @default(1)
  level          RiskLevel           @default(LOW)
  owner          String?
  mitigation     String?
  contingency    String?
  dateIdentified DateTime?            @map("date_identified")
  status         RiskStatus          @default(OPEN)
  trend          String?
  escalate       Boolean             @default(false)
  targetDate     DateTime?           @map("target_date")
  classification ClassificationLevel @default(CUI)
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  branchId      String?       @map("branch_id") @db.Uuid
  programBranch ProgramBranch? @relation(fields: [branchId], references: [id])

  @@unique([orgId, code])
  @@index([orgId, projectId, status])
  @@map("risks")
}

model Deliverable {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String              @map("org_id") @db.Uuid
  projectId        String              @map("project_id") @db.Uuid
  code             String
  title            String
  description      String?
  clin             String?
  status           DeliverableStatus   @default(NOT_STARTED)
  baselineDue      DateTime?           @map("baseline_due")
  actualSubmission DateTime?           @map("actual_submission")
  govAcceptance    DateTime?           @map("gov_acceptance")
  owner            String?
  revisionCycle    Int                 @default(0) @map("revision_cycle")
  escalate         Boolean             @default(false)
  classification   ClassificationLevel @default(CUI)
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  branchId      String?       @map("branch_id") @db.Uuid
  programBranch ProgramBranch? @relation(fields: [branchId], references: [id])
  deliverableType String?               @map("deliverable_type")
  internalReview  DateTime?             @map("internal_review")
  govReviewPeriod Int?                  @map("gov_review_period")
  revRequired     Boolean               @default(false) @map("rev_required")
  milestoneId     String?               @map("milestone_id") @db.Uuid
  milestone       Milestone?            @relation(fields: [milestoneId], references: [id])
  revisions       DeliverableRevision[]
  branchOwner     String?               @map("branch_owner")
  workItemRef     String?               @map("work_item_ref")
  notes           String?

  @@unique([orgId, code])
  @@index([orgId, projectId, status])
  @@map("deliverables")
}

model Blocker {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String              @map("org_id") @db.Uuid
  projectId        String              @map("project_id") @db.Uuid
  code             String
  title            String
  description      String?
  type             BlockerType         @default(INTERNAL)
  status           BlockerStatus       @default(OPEN)
  whatUnblocks     String?             @map("what_unblocks")
  owner            String?
  customerNotified Boolean             @default(false) @map("customer_notified")
  escalate         Boolean             @default(false)
  identifiedAt     DateTime            @default(now()) @map("identified_at")
  resolvedAt       DateTime?           @map("resolved_at")
  classification   ClassificationLevel @default(CUI)
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  branchId      String?       @map("branch_id") @db.Uuid
  programBranch ProgramBranch? @relation(fields: [branchId], references: [id])
  source               String?
  identifiedBy         String?            @map("identified_by")
  decisionAuthority    String?            @map("decision_authority")
  relatedRiskCode      String?            @map("related_risk_code")
  targetDate           DateTime?          @map("target_date")
  customerNotifiedDate DateTime?          @map("customer_notified_date")
  relatedRef           String?            @map("related_ref")
  notes                String?

  @@unique([orgId, code])
  @@index([orgId, projectId, status])
  @@map("blockers")
}

model ChangeRequest {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId              String              @map("org_id") @db.Uuid
  projectId          String              @map("project_id") @db.Uuid
  code               String
  title              String
  description        String?
  type               String?
  status             ChangeRequestStatus @default(SUBMITTED)
  costImpact         Decimal?            @map("cost_impact") @db.Decimal(14, 2)
  scheduleDaysImpact Int?                @map("schedule_days_impact")
  modRequired        Boolean             @default(false) @map("mod_required")
  decidedAt          DateTime?           @map("decided_at")
  classification     ClassificationLevel @default(CUI)
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  branchId      String?       @map("branch_id") @db.Uuid
  programBranch ProgramBranch? @relation(fields: [branchId], references: [id])
  initiatedBy       String?               @map("initiated_by")
  decisionAuthority String?               @map("decision_authority")
  approvedBy        String?               @map("approved_by")
  modNumber         String?               @map("mod_number")
  implDate          DateTime?             @map("impl_date")
  relatedRiskCode   String?               @map("related_risk_code")
  submittedDate     DateTime?             @map("submitted_date")
  scopeImpact       String?               @map("scope_impact")
  notes             String?

  @@unique([orgId, code])
  @@index([orgId, projectId, status])
  @@map("change_requests")
}

// Org-configurable program branch (1.0 Program Mgmt … 6.0 Fielding & Transition).
// First-class dimension referenced by every govcon tracker — powers the
// Domain-Lead persona and all "by branch" rollups.
model ProgramBranch {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  code      String
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org            Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  risks          Risk[]
  changeRequests ChangeRequest[]
  blockers       Blocker[]
  deliverables   Deliverable[]
  milestones     Milestone[]

  @@unique([orgId, code])
  @@map("program_branches")
}

// Deliverable revision cycle (gov returns a CDRL with comments → a new cycle opens).
model DeliverableRevision {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId          String    @map("org_id") @db.Uuid
  deliverableId  String    @map("deliverable_id") @db.Uuid
  cycle          Int       @default(1)
  title          String?
  dateReturned   DateTime? @map("date_returned")
  commentSummary String?   @map("comment_summary")
  owner          String?
  revisedTarget  DateTime? @map("revised_target")
  actualRevised  DateTime? @map("actual_revised")
  daysToResolve  Int?      @map("days_to_resolve")
  govAcceptance  String?   @map("gov_acceptance")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deliverable Deliverable  @relation(fields: [deliverableId], references: [id], onDelete: Cascade)

  @@index([orgId, deliverableId])
  @@map("deliverable_revisions")
}

// A CLIN (Contract Line Item Number) — the cost-rollup dimension. Time entries
// and expenses attribute to a CLIN; burn = labor (hours x cost rate) + expenses
// vs the funded value / ceiling. See lib/pm/burn.ts.
model Clin {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  code        String
  title       String
  value       Decimal   @default(0) @db.Decimal(19, 4) // ceiling
  fundedValue Decimal   @default(0) @map("funded_value") @db.Decimal(19, 4)
  popStart    DateTime? @map("pop_start")
  popEnd      DateTime? @map("pop_end")
  status      String    @default("active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([orgId, projectId, code])
  @@index([orgId, projectId])
  @@map("clins")
}

// A directional cross-reference between two PM entities (or a PM entity and a
// work item). "Soft" references: from/to are (type, id) pairs resolved at read
// time via lib/pm/subjects.ts — no FK relations, so a link can point at any of
// the polymorphic subject kinds without per-kind columns. The detail drawer's
// "Related" tab reads links in either direction and resolves the far end.
model PmLink {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  fromType    String   @map("from_type")
  fromId      String   @map("from_id") @db.Uuid
  toType      String   @map("to_type")
  toId        String   @map("to_id") @db.Uuid
  createdById String   @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([fromType, fromId, toType, toId])
  @@index([orgId, fromType, fromId])
  @@index([orgId, toType, toId])
  @@map("pm_links")
}

/// @-mention backlinks: a `source` (chat message / comment / note / work item)
/// references a `target` entity (any type). Polymorphic + org-scoped, no FKs
/// (target/source span many tables); stale rows resolve to nothing at render.
model Reference {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  sourceType  String   @map("source_type")
  sourceId    String   @map("source_id") @db.Uuid
  targetType  String   @map("target_type")
  targetId    String   @map("target_id") @db.Uuid
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([sourceType, sourceId, targetType, targetId])
  @@index([orgId, targetType, targetId])
  @@index([sourceType, sourceId])
  @@map("entity_references")
}
