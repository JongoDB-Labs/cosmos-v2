  content        String               @default("")
  toolCalls      Json                 @default("[]") @map("tool_calls")
  toolCallId     String?              @map("tool_call_id")
  createdAt      DateTime             @default(now()) @map("created_at")

  conversation AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("assistant_messages")
}

model SavedReport {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  createdById String    @map("created_by_id") @db.Uuid
  name        String
  type        String
  config      Json      @default("{}")
  schedule    String?
  lastRunAt   DateTime? @map("last_run_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, type])
  @@map("saved_reports")
}

// ─────────────────────────────────────────────
// Phase 5a: MCP (Model Context Protocol) servers
// ─────────────────────────────────────────────

model McpServer {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  name       String
  transport  String // "stdio" | "http" | "sse"
  command    String? // for stdio
  args       String[] @default([])
  // env/headers are SEALED at rest (3.13.16): these columns hold the vault envelope
  // of `JSON.stringify(env|headers)`, not the plaintext JSON. Read via the
  // getMcpEnv()/getMcpHeaders() accessors (src/lib/integrations/mcp-secrets.ts).
  // MCP execution is dormant (Phase 0 dropped --mcp-config), so there is no live
  // read path yet — these seal-at-rest on write + the accessor is for when MCP wakes.
  envEnc     String?  @map("env_enc")
  url        String? // for http/sse
  headersEnc String?  @map("headers_enc")
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("mcp_servers")
}

// ─────────────────────────────────────────────
// Phase 5b: Team Chat (channels + DMs + group DMs)
// All Phase 1/2/3 models defined up front so future phases never need destructive migrations.
// ─────────────────────────────────────────────

enum ChatChannelKind {
  CHANNEL
  DM
  GROUP_DM
}

enum ChatChannelMemberRole {
  ADMIN
  MEMBER
}

enum ChatNotificationPref {
  ALL
  MENTIONS
  MUTED
}

model ChatChannel {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String          @map("org_id") @db.Uuid
  kind          ChatChannelKind
  name          String?
  slug          String?
  description   String?
  topic         String?
  isPrivate     Boolean         @default(false) @map("is_private")
  isGeneral     Boolean         @default(false) @map("is_general")
  projectId     String?         @map("project_id") @db.Uuid
  createdById   String          @map("created_by_id") @db.Uuid
  dmKey         String?         @map("dm_key")
  lastMessageAt DateTime?       @map("last_message_at")
  archivedAt    DateTime?       @map("archived_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  org             Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members         ChatChannelMember[]
  messages        ChatMessage[]
  pins            ChatPinnedMessage[]
  // Prod-parity back-relations.
  botChannels     ChatBotChannel[]
  threadFollowers ChatThreadFollower[]

  @@unique([orgId, slug])
  @@unique([orgId, dmKey])
  @@index([orgId, kind, archivedAt])
  @@index([orgId, lastMessageAt])
  @@index([projectId])
  @@map("chat_channels")
}

model ChatChannelMember {
  id                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  channelId         String                @map("channel_id") @db.Uuid
  userId            String                @map("user_id") @db.Uuid
  role              ChatChannelMemberRole @default(MEMBER)
  notificationPref  ChatNotificationPref  @default(MENTIONS) @map("notification_pref")
  lastReadMessageId String?               @map("last_read_message_id") @db.Uuid
  lastReadAt        DateTime?             @map("last_read_at")
  mutedUntil        DateTime?             @map("muted_until")
  // Per-user channel pin (prod-parity): each member pins channels for themselves,
  // so this lives on the membership row (not the channel). Drives sidebar ordering.
  pinned            Boolean               @default(false)
  joinedAt          DateTime              @default(now()) @map("joined_at")

  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId, channelId])
  @@map("chat_channel_members")
}

enum ChatMessageKind {
  USER
  ACTION
  SYSTEM
  ASSISTANT
}

model ChatMessage {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  channelId       String          @map("channel_id") @db.Uuid
  authorId        String          @map("author_id") @db.Uuid
  content         String
  kind            ChatMessageKind @default(USER) @map("kind")
  parentMessageId String?         @map("parent_message_id") @db.Uuid
  editedAt        DateTime?       @map("edited_at")
  deletedAt       DateTime?       @map("deleted_at")
  createdAt       DateTime        @default(now()) @map("created_at")

  channel         ChatChannel             @relation(fields: [channelId], references: [id], onDelete: Cascade)
  parentMessage   ChatMessage?            @relation("Thread", fields: [parentMessageId], references: [id])
  replies         ChatMessage[]           @relation("Thread")
  reactions       ChatMessageReaction[]
  attachments     ChatMessageAttachment[]
  mentions        ChatMessageMention[]
  pins            ChatPinnedMessage[]
  // Prod-parity back-relations.
  botRuns         ChatBotRun[]
  threadFollowers ChatThreadFollower[]    @relation("ThreadFollowers")

  @@index([channelId, createdAt])
  @@index([channelId, parentMessageId, createdAt])
  @@index([authorId, createdAt])
  @@map("chat_messages")
}

model ChatMessageReaction {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("chat_message_reactions")
}

model ChatMessageAttachment {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId    String?  @map("message_id") @db.Uuid
  kind         String
  url          String
  storageKey   String   @map("storage_key")
  filename     String
  contentType  String   @map("content_type")
  size         Int
  width        Int?
  height       Int?
  uploadedById String   @map("uploaded_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  message ChatMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([uploadedById, createdAt])
  @@map("chat_message_attachments")
}

model ChatMessageMention {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, createdAt])
  @@map("chat_message_mentions")
}

model ChatPinnedMessage {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  channelId  String   @map("channel_id") @db.Uuid
  messageId  String   @map("message_id") @db.Uuid
  pinnedById String   @map("pinned_by_id") @db.Uuid
  pinnedAt   DateTime @default(now()) @map("pinned_at")

  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([channelId, messageId])
  @@index([channelId, pinnedAt])
  @@map("chat_pinned_messages")
}

// ─────────────────────────────────────────────
// OKRs (Objectives & Key Results)
// ─────────────────────────────────────────────

enum ObjectiveStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum KeyResultStatus {
  NOT_STARTED
  IN_PROGRESS
  AT_RISK
  ON_TRACK
  DONE
}

// Stoplight health: on-track / at-risk / behind. Shared health language for OKR
// check-ins (and, later, deliverables/milestones) — see the OKR redesign.
enum RagStatus {
  GREEN
  YELLOW
  RED
}

model Objective {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String          @map("org_id") @db.Uuid
  projectId   String          @map("project_id") @db.Uuid
  title       String
  description String?
  ownerId     String?         @map("owner_id") @db.Uuid
  period      String?
  status      ObjectiveStatus @default(ACTIVE)
  progress    Int             @default(0) // 0-100, derived from key results
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  keyResults KeyResult[]

  @@index([orgId, projectId])
  @@map("objectives")
}

model KeyResult {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  objectiveId  String          @map("objective_id") @db.Uuid
  title        String
  description  String?
  startValue   Float           @default(0) @map("start_value")
  currentValue Float           @default(0) @map("current_value")
  targetValue  Float           @default(100) @map("target_value")
  unit         String          @default("")
  status       KeyResultStatus @default(NOT_STARTED)
  ownerId      String?         @map("owner_id") @db.Uuid
  sortOrder    Int             @default(0) @map("sort_order")
  // Latest check-in snapshot, denormalized so a board load needs no subquery.
  // Null until the first check-in. The full history lives in KeyResultCheckin.
  confidence   Int?            // 0-100, from the latest check-in
  rag          RagStatus?      // stoplight, from the latest check-in
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  objective Objective          @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  checkins  KeyResultCheckin[]

  @@index([objectiveId])
  @@map("key_results")
}

// A point-in-time check-in on a key result: the value + confidence + stoplight at
// that moment, plus a note and any blockers. This time-series is what the OKR
// stoplight-over-time grid + exec attention panel (P2) read.
model KeyResultCheckin {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  keyResultId   String    @map("key_result_id") @db.Uuid
  value         Float
  confidence    Int       @default(50) // 0-100
  rag           RagStatus
  note          String?
  blockers      String?
  checkedInById String?   @map("checked_in_by_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")

  keyResult KeyResult @relation(fields: [keyResultId], references: [id], onDelete: Cascade)

  @@index([keyResultId, createdAt])
  @@map("key_result_checkins")
}

// ─────────────────────────────────────────────
// Goals, Milestones, KPIs (project delivery tracking)
// ─────────────────────────────────────────────

enum GoalStatus {
  PLANNED
  ON_TRACK
  AT_RISK
  OFF_TRACK
  ACHIEVED
}

enum GoalProgressMode {
  MANUAL
  AUTO
}

enum GoalLinkKind {
  WORK_ITEM
  OBJECTIVE
}

model Goal {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String           @map("org_id") @db.Uuid
  projectId    String           @map("project_id") @db.Uuid
  title        String
  description  String?
  status       GoalStatus       @default(PLANNED)
  progress     Int              @default(0) // 0-100; manual or rolled up from links
  progressMode GoalProgressMode @default(MANUAL) @map("progress_mode")
  targetDate   DateTime?        @map("target_date")
  ownerId      String?          @map("owner_id") @db.Uuid
  sortOrder    Int              @default(0) @map("sort_order")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  links   GoalLink[]

  @@index([orgId, projectId])
  @@map("goals")
}

// Links a goal to a work item OR an OKR objective (the rollup source for AUTO
// progress). Soft references by id (no hard FK) so deleting a linked item never
// cascades into the goal; the resolver tolerates dangling links.
model GoalLink {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  goalId      String       @map("goal_id") @db.Uuid
  kind        GoalLinkKind
  workItemId  String?      @map("work_item_id") @db.Uuid
  objectiveId String?      @map("objective_id") @db.Uuid
  createdAt   DateTime     @default(now()) @map("created_at")

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@map("goal_links")
}

enum MilestoneStatus {
  UPCOMING
  IN_PROGRESS
  COMPLETED
  MISSED
}

model Milestone {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String          @map("org_id") @db.Uuid
  projectId   String          @map("project_id") @db.Uuid
  title       String
  description String?
  dueDate     DateTime        @map("due_date")
  status      MilestoneStatus @default(UPCOMING)
  autoStatus  Boolean         @default(true) @map("auto_status") // derive from linked items
  completedAt DateTime?       @map("completed_at")
  ownerId     String?         @map("owner_id") @db.Uuid
  sortOrder   Int             @default(0) @map("sort_order")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  org     Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  branchId      String?       @map("branch_id") @db.Uuid
  programBranch ProgramBranch? @relation(fields: [branchId], references: [id])
  baselineDate     DateTime?     @map("baseline_date")
  projectedDate    DateTime?     @map("projected_date")
  actualDate       DateTime?     @map("actual_date")
  rootCause        String?       @map("root_cause")
  recoveryPlan     String?       @map("recovery_plan")
  recoveryTarget   DateTime?     @map("recovery_target")
  phase            String?
  scheduleEscalate Boolean       @default(false) @map("schedule_escalate")
  milestoneType    String?       @map("milestone_type")
  downstreamImpact String?       @map("downstream_impact")
  relatedRef       String?       @map("related_ref")
  notes            String?
  deliverables     Deliverable[]
  links   MilestoneLink[]

  @@index([orgId, projectId])
  @@map("milestones")
}

model MilestoneLink {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  milestoneId String   @map("milestone_id") @db.Uuid
  workItemId  String   @map("work_item_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@index([milestoneId])
  @@map("milestone_links")
}

enum KpiDirection {
  UP_GOOD
  DOWN_GOOD
}

// How a KPI's currentValue is sourced. MANUAL = typed in; the rest derive from
// execution (work items + cycles) — see lib/pm/kpi-derive.
enum KpiAutoSource {
  MANUAL
  VELOCITY        // avg story points delivered per completed cycle
  COMPLETION_PCT  // % of work items done
  THROUGHPUT      // items completed within the rolling window
  OPEN_ITEMS      // count of not-done work items
  AVG_CYCLE_TIME  // avg days from start to done
}

model Kpi {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String       @map("org_id") @db.Uuid
  projectId    String       @map("project_id") @db.Uuid
  name         String
  description  String?
  unit         String       @default("")
  targetValue  Float        @default(0) @map("target_value")
  currentValue Float        @default(0) @map("current_value")
  direction    KpiDirection @default(UP_GOOD)
  autoSource   KpiAutoSource @default(MANUAL) @map("auto_source")
  autoWindowDays Int?        @map("auto_window_days") // rolling window for THROUGHPUT (default 30)
  sortOrder    Int          @default(0) @map("sort_order")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  org        Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dataPoints KpiDataPoint[]

  @@index([orgId, projectId])
  @@map("kpis")
}

// A measurement of a KPI at a point in time — powers the trend chart and keeps
// the KPI's currentValue in sync (the API stamps currentValue from the latest).
model KpiDataPoint {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kpiId      String   @map("kpi_id") @db.Uuid
  value      Float
  recordedAt DateTime @default(now()) @map("recorded_at")
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")

  kpi Kpi @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@index([kpiId, recordedAt])
  @@map("kpi_data_points")
}

// ─────────────────────────────────────────────
// Roadmap — project-scoped reference surface that renders a program roadmap
// (sections, sub-phases SP-x, lines-of-effort LOE-x, risks R-xx, decisions DP-xx,
// stakeholders, milestones) as navigable, deep-linkable nodes. Issue descriptions
// link to a node as source-of-truth instead of restating it. Seeded/imported from
// the authoritative roadmap document; CUI-adjacent content lives only in the tenant.
// ─────────────────────────────────────────────

enum RoadmapNodeKind {
  SECTION
  SUBPHASE
  LOE
  RISK
  DECISION
  STAKEHOLDER
  MILESTONE
}

model RoadmapNode {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String          @map("org_id") @db.Uuid
  projectId   String          @map("project_id") @db.Uuid
  kind        RoadmapNodeKind
  // Human external ref + deep-link key, e.g. "R-19" / "DP-04" / "SP-3" / "LOE-2"
  // / "S-19". Null for nodes without a formal id (some stakeholders/milestones).
  externalRef String?         @map("external_ref")
  // Source section number/label, e.g. "19" — a reading aid for grouping.
  section     String?
  // Category band within a register, e.g. "ATO & AUTHORIZATION" (risks/decisions).
  category    String?
  title       String
  body        String          @default("")
  // Stable URL slug for deep-linking, e.g. "r-19" / "dp-04". Unique per project.
  anchor      String
  // Kind-specific structured extras (likelihood/impact/owner, decision date, etc.).
  meta        Json            @default("{}")
  sortOrder   Int             @default(0) @map("sort_order")
  // Self-relation: SUBPHASE/LOE/RISK/DECISION under a SECTION. Parent delete nulls.
  parentId    String?         @map("parent_id") @db.Uuid
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  org      Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent   RoadmapNode?  @relation("RoadmapNodeHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children RoadmapNode[] @relation("RoadmapNodeHierarchy")

  // One human ref per project (NULLs are distinct in Postgres, so id-less nodes coexist).
  @@unique([orgId, projectId, externalRef])
  // Stable anchor slug per project for deep-links.
  @@unique([orgId, projectId, anchor])
  @@index([orgId, projectId])
  @@index([orgId, projectId, kind])
  @@index([parentId])
  @@map("roadmap_nodes")
}

// ─────────────────────────────────────────────
// Feedback portal (feature requests & bug reports)
// ─────────────────────────────────────────────

enum FeedbackType {
  BUG
  FEATURE
}

enum FeedbackStatus {
  OPEN
  PLANNED
  IN_PROGRESS
  DONE
  DECLINED
}

model FeedbackItem {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String         @map("org_id") @db.Uuid
  authorId    String         @map("author_id") @db.Uuid
  type        FeedbackType   @default(FEATURE)
  title       String
  description String         @default("")
  status      FeedbackStatus @default(OPEN)
  voteCount   Int            @default(0) @map("vote_count") // denormalized for sort
  // Auto-captured client context on BUG reports (route, userAgent, stack,
  // componentStack, digest, errorSignature). Append-only sightings; {} for FRs.
  telemetry   Json           @default("{}")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  org         Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  votes       FeedbackVote[]
  attachments FeedbackAttachment[]

  @@index([orgId, status])
  @@map("feedback_items")
}

// Screenshot/file attachments on a feedback item. Mirrors ChatMessageAttachment:
// orphaned (feedbackItemId null) until the feedback POST associates it; served
// through an auth-checked route, not the raw storage URL. (FR: attach screenshots
// to bug/FR tickets, viewable by admins.)
model FeedbackAttachment {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  feedbackItemId String?  @map("feedback_item_id") @db.Uuid
  orgId          String   @map("org_id") @db.Uuid
  kind           String
  url            String
  storageKey     String   @map("storage_key")
  filename       String
  contentType    String   @map("content_type")
  size           Int
  uploadedById   String   @map("uploaded_by_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  feedbackItem FeedbackItem? @relation(fields: [feedbackItemId], references: [id], onDelete: Cascade)

  @@index([feedbackItemId])
  @@index([uploadedById, createdAt])
  @@map("feedback_attachments")
}

model FeedbackVote {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  feedbackItemId String   @map("feedback_item_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  feedbackItem FeedbackItem @relation(fields: [feedbackItemId], references: [id], onDelete: Cascade)

  @@unique([feedbackItemId, userId])
  @@index([feedbackItemId])
  @@map("feedback_votes")
}

// ─────────────────────────────────────────────
// Personal Home dashboard widgets
// ─────────────────────────────────────────────

model HomeWidget {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  ownerId   String   @map("owner_id") @db.Uuid
  type      String
  config    Json     @default("{}")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // One widget of each type per user per org; the unique index also serves the
  // (orgId, ownerId) list lookup as a prefix.
  @@unique([orgId, ownerId, type])
  @@map("home_widgets")
}

// ─────────────────────────────────────────────
// Work-role ABAC: grantable, attribute-aware roles layered on the bitfield
// ─────────────────────────────────────────────

model WorkRole {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  key         String
  name        String
  description String?
  // Extra Permission bits this role GRANTS on top of the org role (BigInt). The
  // grant layer only ever WIDENS the bitfield — never serialize this raw to
  // JSON (toString it in API responses).
  grants      BigInt   @default(0)
  // AbacRule[] (see src/lib/abac/engine.ts) that NARROW access for members of
  // this role. Stored as a JSON array.
  policies    Json     @default("[]")
  isBuiltIn   Boolean  @default(false) @map("is_built_in")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org     Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members OrgMemberWorkRole[]

  @@unique([orgId, key])
  @@map("work_roles")
}

model OrgMemberWorkRole {
  orgMemberId String   @map("org_member_id") @db.Uuid
  workRoleId  String   @map("work_role_id") @db.Uuid
  // Optional attribute scoping for THIS assignment (e.g. { projectIds: [...] });
  // reserved for a later iteration.
  scope       Json?
  createdAt   DateTime @default(now()) @map("created_at")

  orgMember OrgMember @relation(fields: [orgMemberId], references: [id], onDelete: Cascade)
  workRole  WorkRole  @relation(fields: [workRoleId], references: [id], onDelete: Cascade)

  @@id([orgMemberId, workRoleId])
  @@index([workRoleId])
  @@map("org_member_work_roles")
}

// ─────────────────────────────────────────────
// Finance Step 1a — General Ledger Engine
// ─────────────────────────────────────────────

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum JournalSource {
  MANUAL
  REVENUE
  EXPENSE
  INVOICE
  PAYMENT
  PAYROLL
}

enum JournalStatus {
  DRAFT
  POSTED
  VOID
}

enum EntryDirection {
  DEBIT
  CREDIT
}

enum PeriodStatus {
  OPEN
  CLOSED
}

model Account {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String        @map("org_id") @db.Uuid
  code          String
  name          String
  type          AccountType
  normalBalance NormalBalance @map("normal_balance")
  parentId      String?       @map("parent_id") @db.Uuid
  isActive      Boolean       @default(true) @map("is_active")
  isSystem      Boolean       @default(false) @map("is_system")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  parent        Account?      @relation("AccountTree", fields: [parentId], references: [id])
  children      Account[]     @relation("AccountTree")
  lines         JournalLine[]

  @@unique([orgId, code])
  @@index([orgId, type])
  @@map("accounts")
}

model JournalEntry {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String         @map("org_id") @db.Uuid
  entryNumber Int            @map("entry_number")
  date        DateTime       @db.Date
  memo        String         @default("")
  status      JournalStatus  @default(POSTED)
  source      JournalSource  @default(MANUAL)
  sourceId    String?        @map("source_id") @db.Uuid
  reversesId  String?        @map("reverses_id") @db.Uuid
  postedAt    DateTime?      @map("posted_at")
  createdById String         @map("created_by_id") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  reverses    JournalEntry?  @relation("Reversal", fields: [reversesId], references: [id])
  reversedBy  JournalEntry[] @relation("Reversal")
  lines       JournalLine[]

  @@unique([orgId, entryNumber])
  @@unique([orgId, source, sourceId])
  @@unique([orgId, reversesId])
  @@index([orgId, date])
  @@index([orgId, status])
  @@map("journal_entries")
}

model JournalLine {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String         @map("org_id") @db.Uuid
  journalEntryId  String         @map("journal_entry_id") @db.Uuid
  accountId       String         @map("account_id") @db.Uuid
  direction       EntryDirection
  amount          Decimal        @db.Decimal(19, 4)
  description     String?
  sortOrder       Int            @default(0) @map("sort_order")
  projectId       String?        @map("project_id") @db.Uuid
  contractId      String?        @map("contract_id") @db.Uuid
  costObjectiveId String?        @map("cost_objective_id") @db.Uuid
  costPoolId      String?        @map("cost_pool_id") @db.Uuid
  entry           JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account         Account        @relation(fields: [accountId], references: [id], onDelete: Restrict)
  project         Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  contract        Contract?      @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@index([orgId, accountId])
  @@index([journalEntryId])
  @@index([orgId, projectId])
  @@map("journal_lines")
}

model AccountingPeriod {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String       @map("org_id") @db.Uuid
  startDate  DateTime     @map("start_date") @db.Date
  endDate    DateTime     @map("end_date") @db.Date
  status     PeriodStatus @default(OPEN)
  closedAt   DateTime?    @map("closed_at")
  closedById String?      @map("closed_by_id") @db.Uuid

  @@unique([orgId, startDate])
  @@index([orgId, status])
  @@map("accounting_periods")
}

// ═════════════════════════════════════════════════════════════════════════════
// PROD-PARITY MODELS (migration 20260607030000_prod_parity_reconciliation)
//
// 18 tables ported VERBATIM from prod (/home/defcon/cosmos-prod) so the
// per-tenant cutover does a lossless structural copy of prod rows into v2.
// SHAPE matches prod EXACTLY (column types/nullability/defaults/@map/indexes/
// FKs) — do NOT "improve" these; a divergence breaks the cutover parity gate.
//
//  • FULLY WIRED (prod has rows): ChatBot (12) + WorkItemLink (42).
//  • SCHEMA-ONLY (empty in prod; ports the shape so data migrates + the parity
//    gate is clean — UI/routes deferred to roadmap): the finance tables
//    (Invoice/InvoiceLineItem/Payment/Employee/PayRun/TaxRate, Bank*),
//    Document, OrgAiSettings, the chat aux tables (ChatThreadFollower /
//    ChatAlertKeyword / ChatBotChannel / ChatBotRun), WorkItemAttachment.
// ═════════════════════════════════════════════════════════════════════════════

/// Per-org AI provider credentials (one row per org). Secret values are stored
/// as AES-256-GCM blobs encrypted with the app key — never plaintext. SCHEMA-ONLY
/// in v2 today (v2 resolves provider creds via its own ConnectorCredential vault);
/// ported so any prod rows migrate. TODO(roadmap): reconcile with v2 creds store.
model OrgAiSettings {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId             String    @unique @map("org_id") @db.Uuid
  provider          String    @default("anthropic")
  model             String?
  anthropicApiKey   Json?     @map("anthropic_api_key")
  claudeOAuthToken  Json?     @map("claude_oauth_token")
  openaiApiKey      Json?     @map("openai_api_key")
  oauthAccessToken  Json?     @map("oauth_access_token")
  oauthRefreshToken Json?     @map("oauth_refresh_token")
  oauthExpiresAt    DateTime? @map("oauth_expires_at")
  updatedById       String?   @map("updated_by_id") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("org_ai_settings")
}

// PER-USER Claude subscription OAuth — the agent prefers the requesting USER's
// personal Claude token over the org's (FR: "tied to user's oauth/token not
// org-wide"). Mirrors the OAuth columns of OrgAiSettings, keyed on userId.
// Tokens are SEALED via the vault before they touch the DB (Json { sealed }).
// Resolution happens INSIDE the single CUI-blind egress chokepoint, after
// withholding — this row never widens egress.
model UserAiSettings {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @unique @map("user_id") @db.Uuid
  provider          String    @default("claude-oauth")
  oauthAccessToken  Json?     @map("oauth_access_token")
  oauthRefreshToken Json?     @map("oauth_refresh_token")
  oauthExpiresAt    DateTime? @map("oauth_expires_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_ai_settings")
}

// Directed dependency/relation edge between two work items (FULLY WIRED).
model WorkItemLink {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  sourceItemId String   @map("source_item_id") @db.Uuid
  targetItemId String   @map("target_item_id") @db.Uuid
  type         LinkType
  createdAt    DateTime @default(now()) @map("created_at")

  sourceItem WorkItem @relation("WorkItemLinkSource", fields: [sourceItemId], references: [id], onDelete: Cascade)
  targetItem WorkItem @relation("WorkItemLinkTarget", fields: [targetItemId], references: [id], onDelete: Cascade)

  @@index([orgId, sourceItemId])
  @@map("work_item_links")
}

// Attachment metadata for a work item (SCHEMA-ONLY; no upload UI in v2 yet).
model WorkItemAttachment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  workItemId  String   @map("work_item_id") @db.Uuid
  fileName    String   @map("file_name")
  url         String
  mimeType    String?  @map("mime_type")
