model OrgSecuritySettings {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId              String   @unique @map("org_id") @db.Uuid
  mfaRequired        Boolean  @default(false) @map("mfa_required")
  sessionTimeoutMins Int      @default(480) @map("session_timeout_mins")
  ipAllowlistEnabled Boolean  @default(false) @map("ip_allowlist_enabled")
  scimEnabled        Boolean  @default(false) @map("scim_enabled")
  ssoEnforced        Boolean  @default(false) @map("sso_enforced")
  ssoConnectionId    String?  @map("sso_connection_id")
  allowedDomains     String[] @default([]) @map("allowed_domains")
  auditRetentionDays Int      @default(365) @map("audit_retention_days")

  // ── Session policy (prod-parity; enforced server-side in the auth path) ──────
  // Absolute max age of a session regardless of activity (minutes). 0 disables
  // the absolute cap and falls back to the session's own expiry.
  maxSessionAgeMins     Int @default(0) @map("max_session_age_mins")
  // Idle timeout: invalidate after this many minutes with no activity. 0 disables.
  idleTimeoutMins       Int @default(0) @map("idle_timeout_mins")
  // Max concurrent ACTIVE sessions per user. 0 = unlimited.
  maxConcurrentSessions Int @default(0) @map("max_concurrent_sessions")

  // ── MFA enrollment readiness flag (prod-parity) ─────────────────────────────
  // Gates the mfaRequired enforcement hook until first-party enrollment ships.
  // When false (default) the MFA gate is INERT.
  mfaEnrollmentReady Boolean @default(false) @map("mfa_enrollment_ready")

  // ── Per-action restrictions (prod-parity; org-level ABAC deny rules) ─────────
  // Org-wide DENY rules folded into the actor's abacRules and evaluated by the
  // existing ABAC engine. Shape: { rules: AbacRule[] } or AbacRule[].
  actionRestrictions Json @default("{}") @map("action_restrictions")

