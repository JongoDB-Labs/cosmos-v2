# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but track the committed template (contains no secrets)
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code worktrees + Superpowers brainstorm scratch
.claude/
.superpowers/

# user-uploaded assets
/public/uploads/
test-results
/uploads/

# scratch audit/verify scripts (never commit)
/.r*.mjs

# DSOP local-proof artifacts (real scan/SBOM/signature output — proof, not source)
/evidence/
# local cosign keypair generated by build-sign-local.sh (never commit keys)
cosign.key
cosign.pub
cosign.password

# SSO Docker acceptance: throwaway dex IdP override carries a throwaway client
# secret + test-user password hash — never commit it. The runbook (docs/) is fine.
docker-compose.dex.yml
/docs/sso-acceptance/*.local.*
/docs/sso-acceptance/evidence/

# MinIO self-signed TLS material is generated at runtime into a Docker volume by the
# minio-certs one-shot — NEVER commit a private key. Defensive guard in case a cert is
# ever written into the worktree out-of-band.
compose/minio/certs/
