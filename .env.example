# --- cosmos app ---
# DATABASE_URL/DIRECT_URL here are the OWNER (cosmos) creds used by cosmos-migrate to
# run `prisma migrate deploy`. In docker-compose the `cosmos` app service overrides
# these to connect as the least-privilege `cosmos_app` role (no UPDATE/DELETE/TRUNCATE
# on the audit tables — AU-9). On a PRE-EXISTING DB volume the init script that creates
# the role does NOT re-run; create `cosmos_app` + re-run the migration's idempotent
# GRANTs manually.
DATABASE_URL=postgres://cosmos:cosmos@cosmos-postgres:5432/cosmos
DIRECT_URL=postgres://cosmos:cosmos@cosmos-postgres:5432/cosmos
# Password for the cosmos_app least-privilege app role (created at DB init).
COSMOS_APP_PASSWORD=cosmos_app
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_MODEL=claude-sonnet-4-6
GOOGLE_CLIENT_ID=REPLACE_ME
GOOGLE_CLIENT_SECRET=REPLACE_ME
GOOGLE_REDIRECT_URI=https://localhost/api/auth/google/callback
ALLOWED_EMAILS=you@example.com
# E2E_TEST_AUTH MUST be unset in any non-test stack (it enables an auth-bypass route).
