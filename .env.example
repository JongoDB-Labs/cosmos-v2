# --- cosmos app ---
# DATABASE_URL/DIRECT_URL here are the OWNER (cosmos) creds used by cosmos-migrate to
# run `prisma migrate deploy`. In docker-compose the `cosmos` app service overrides
# these to connect as the least-privilege `cosmos_app` role (no UPDATE/DELETE/TRUNCATE
# on the audit tables — AU-9). On a PRE-EXISTING DB volume the init script that creates
# the role does NOT re-run; create `cosmos_app` + re-run the migration's idempotent
# GRANTs manually.
DATABASE_URL=postgres://cosmos:cosmos@cosmos-postgres:5432/cosmos
DIRECT_URL=postgres://cosmos:cosmos@cosmos-postgres:5432/cosmos
# Password for the cosmos_app least-privilege app role (created at DB init).
COSMOS_APP_PASSWORD=cosmos_app
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_MODEL=claude-sonnet-4-6
# Web Push (VAPID) — REQUIRED for browser push notifications (Settings → Profile →
# "Enable push notifications"). Without these the GET /api/v1/me/push/subscribe
# endpoint returns 503 and the toggle reports "not configured on this server".
# Generate a keypair with:  npx web-push generate-vapid-keys
# VAPID_SUBJECT must be a mailto: or https: contact URL for your deployment.
VAPID_PUBLIC_KEY=REPLACE_WITH_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=REPLACE_WITH_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:you@example.com
GOOGLE_CLIENT_ID=REPLACE_ME
GOOGLE_CLIENT_SECRET=REPLACE_ME
GOOGLE_REDIRECT_URI=https://localhost/api/auth/google/callback
ALLOWED_EMAILS=you@example.com
# Platform-owner allowlist (comma-separated emails). These identities reach the
# /internal surface AND are the break-glass exemption from the gov enforced-SSO
# guard (the interim gov-lockout recovery path; see HANDOFF.md "Break-glass").
INTERNAL_ADMINS=you@example.com
# SSO secret vault — seals per-tenant OIDC client secrets at rest (AES-256-GCM) via
# src/lib/crypto/vault.ts. The vault is a KEYRING (multiple keys, one active) so the
# master key can be ROTATED without downtime: add a new key, re-wrap all secrets to it
# (scripts/dsop/rotate-vault-key.mjs), then retire the old key. See the rotate-then-retire
# procedure in docs/runbooks/secret-rotation.md.
#
#   SSO_VAULT_KEYS       JSON keyring {"<kid>":"<base64 32-byte key>", ...}; kid charset [A-Za-z0-9_-].
#   SSO_VAULT_ACTIVE_KID the kid NEW secrets seal under (must be one of the ring's kids).
#
# BACKWARD COMPAT: if SSO_VAULT_KEYS is unset but the single SSO_VAULT_KEY (a 32-byte base64
# key) is set, the ring is synthesized as {"v1": <SSO_VAULT_KEY>} with active kid "v1" — an
# existing single-key deployment keeps working with ZERO config change, and existing
# v1.<iv>.<tag>.<ct> blobs still open. Once SSO_VAULT_KEYS is set, SSO_VAULT_KEY is ignored.
# In PRODUCTION inject these as Docker/orchestrator secrets, NOT plaintext env vars. The
# `cosmos` app service reads them via env_file; the migrate service does NOT need them, but
# the rotate-vault-key one-shot DOES (it re-seals under the active kid).
# Generate a key with: `openssl rand -base64 32`.
SSO_VAULT_KEY=REPLACE_WITH_32_BYTE_BASE64
# Example keyring during a rotation (old + new in the ring, sealing under the new key):
#   SSO_VAULT_KEYS={"v1":"<OLD_32_BYTE_BASE64>","v2k":"<NEW_32_BYTE_BASE64>"}
#   SSO_VAULT_ACTIVE_KID=v2k
# SSO_VAULT_KEYS=
# SSO_VAULT_ACTIVE_KID=
# E2E_TEST_AUTH MUST be unset in any non-test stack (it enables an auth-bypass route).

# --- in-boundary object storage (MinIO; GovCloud/Assured-Workloads S3 in prod) ---
# STORAGE_ADAPTER=s3 routes uploads through MinIO. In docker-compose the cosmos
# service already sets these via `environment:`; set them here only when running the
# app outside compose. forcePathStyle defaults on (MinIO requires it).
STORAGE_ADAPTER=s3
# HTTPS — MinIO serves a self-signed internal cert (generated into the certs volume by
# the minio-certs one-shot). The cosmos/audit-worm services trust it via
# NODE_EXTRA_CA_CERTS (set in compose) rather than disabling TLS verification globally.
S3_ENDPOINT=https://cosmos-minio:9000
S3_BUCKET=cosmos-uploads
# MinIO root creds (admin). In PROD inject as Docker/orchestrator secrets, never plaintext.
MINIO_ROOT_USER=cosmos-minio-root
MINIO_ROOT_PASSWORD=REPLACE_ME_MINIO_ROOT
# Least-privilege app key: RW on cosmos-uploads + cosmos-pgbackrest ONLY (no audit-worm).
S3_ACCESS_KEY=cosmos-app
S3_SECRET_KEY=REPLACE_ME_APP_SECRET
# Least-privilege WORM key: APPEND-ONLY on the object-locked cosmos-audit-worm — write +
# read for verification (GetObject), NO delete / overwrite / retention-bypass. Read is
# granted on purpose: a verifier diffing the live DB against the WORM copy needs it (AU-9).
WORM_ACCESS_KEY=cosmos-worm
WORM_SECRET_KEY=REPLACE_ME_WORM_SECRET
# Object-lock COMPLIANCE retention (days) applied to every audit-worm object at create.
WORM_RETENTION_DAYS=3650
# HMAC key for signing the audit-export manifest (detects manifest tampering). Rotate
# on compromise; the WORM copy of past manifests stays verifiable under the old key.
WORM_MANIFEST_HMAC_KEY=REPLACE_ME_MANIFEST_HMAC
# DB connection for the audit-worm-export job. Defaults (in docker-compose) to the
# LEAST-PRIVILEGE cosmos_app role — SELECT-only on the audit tables (REVOKEd
# UPDATE/DELETE/TRUNCATE; does NOT own the append-only triggers). The exporter only ever
# reads, so it must NOT use the owner (cosmos) creds. Override only if the read role differs.
WORM_EXPORT_DATABASE_URL=postgres://cosmos_app:cosmos_app@cosmos-postgres:5432/cosmos

# --- pgBackRest (Postgres backup/DR → MinIO S3 repo; CP-9/CP-10) ---
# Repo encryption passphrase (aes-256-cbc at the repo layer). REQUIRED; losing it makes
# the backups unrecoverable. In PROD inject as a Docker/orchestrator secret.
PGBACKREST_CIPHER_PASS=REPLACE_ME_BACKUP_CIPHER
# S3 endpoint HOST for pgBackRest (no scheme/port; the port is repo1-s3-port=9000 in the
# conf template). pgBackRest's S3 repo ALWAYS uses TLS — MinIO serves HTTPS with the
# self-signed internal cert and pgBackRest skips CA verification (repo1-storage-verify-tls=n).
# In prod point this at the GovCloud S3 endpoint and flip verify-tls=y.
S3_ENDPOINT_HOST=cosmos-minio

# --- observability (SI-4 / 800-171 3.14.6-3.14.7) — OBSERVE-ONLY OTel export ---
# The app exports traces + custom metrics (egress decisions/errors, classifier
# invocations/errors/latency, HTTP metrics) over OTLP to an in-boundary OTel Collector.
# Export is fire-and-forget: when the collector is absent/unreachable the SDK logs +
# retries and the app keeps running (base `up` without the observability profile is fine).
# In docker-compose the `cosmos` service already sets these via `environment:` when the
# observability profile is up; set them here only when running the app outside compose.
# Point these at a gov enterprise OTel/SIEM backend in prod — the app side is unchanged.
#   OTEL_EXPORTER_OTLP_ENDPOINT   base OTLP endpoint (NO endpoint set ⇒ metrics no-op)
#   OTEL_EXPORTER_OTLP_PROTOCOL   http/protobuf (matches the collector's OTLP/HTTP receiver)
#   OTEL_SERVICE_NAME             the service name in traces/metrics (defaults to cosmos-v2)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_SERVICE_NAME=cosmos-v2

# --- Grafana admin (observability profile only; NEVER commit real creds) ---
# Consumed by the grafana sidecar. Placeholders only here — set real values in .env.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=REPLACE_ME_GRAFANA_ADMIN

# --- Nango (self-hosted OSS unified-API/OAuth broker; `nango` compose profile) ---
# COMMERCIAL-ONLY connector breadth (~180 providers) wired through the v2.10 connector
# registry + the egress chokepoint. The app talks to Nango server-side over the INTERNAL
# compose network ONLY. A gov tenant is CODE-BLOCKED from reaching Nango by any path
# (tool-list filter, dispatch refusal, executor hard-check, connect-route 403) — D5.
#
#   NANGO_HOST         the in-boundary Nango server URL the APP uses. In docker-compose
#                      the `cosmos` service already defaults this to the internal name
#                      (http://cosmos-nango-server:3003). Set here only when running the
#                      app outside compose. When unset (with NANGO_SECRET_KEY), the Nango
#                      connector is DISABLED (nangoEnabled()=false) and degrades gracefully.
#   NANGO_SECRET_KEY   the self-hosted Nango ENVIRONMENT's API secret key (the @nangohq/node
#                      SDK auth). A PLATFORM secret — NEVER committed, NEVER logged. In PROD
#                      inject as a Docker/orchestrator secret, NOT a plaintext env var. On a
#                      fresh self-host you obtain it from the Nango dashboard (or seed it);
#                      until set, the Nango connector stays DISABLED.
NANGO_HOST=http://cosmos-nango-server:3003
NANGO_SECRET_KEY=REPLACE_ME_NANGO_SECRET_KEY
#
# --- Nango SERVER-side config (consumed by the `nango` profile services) ---
#   NANGO_ENCRYPTION_KEY  REQUIRED for the Connect UI / session encryption — a base64
#                         32-byte key (`openssl rand -base64 32`). WARNING: cannot be
#                         changed once data is encrypted under it.
#   NANGO_DASHBOARD_*     basic-auth creds protecting the Nango dashboard (self-host).
#   NANGO_DB_*            Nango's dedicated Postgres (separate from cosmos-postgres).
#   NANGO_SERVER_URL / NANGO_PUBLIC_SERVER_URL  the externally-reachable URL for OAuth
#                         callbacks + the Connect UI (default http://localhost:3013 — the
#                         host-published server port). Point at the public origin in prod.
NANGO_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_BASE64
NANGO_DASHBOARD_USERNAME=nango
NANGO_DASHBOARD_PASSWORD=REPLACE_ME_NANGO_DASHBOARD
NANGO_DB_USER=nango
NANGO_DB_PASSWORD=REPLACE_ME_NANGO_DB
NANGO_DB_NAME=nango
NANGO_SERVER_URL=http://localhost:3013
NANGO_PUBLIC_SERVER_URL=http://localhost:3013
