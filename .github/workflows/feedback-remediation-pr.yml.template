# ─────────────────────────────────────────────────────────────────────────────
# feedback-remediation-pr  —  PR-DRAFTING BRIDGE (opt-in, rename to activate)
# ─────────────────────────────────────────────────────────────────────────────
# This is a TEMPLATE, not a live workflow. It ships with a `.template` suffix so
# it can NEVER run (and can't trip CI/security scanners) until you deliberately
# adopt it by renaming to `feedback-remediation-pr.yml`.
#
# What it does: given a delivered feedback work item (ticket key or description),
# it runs an autonomous coding agent that DRAFTS a fix and opens a **draft** pull
# request for your review. It NEVER marks a PR ready, NEVER merges, and NEVER
# deploys — a human always approves.
#
# Activation checklist:
#   1. Review this file end-to-end; you are enabling an agent to write code in CI.
#   2. Add secret ANTHROPIC_API_KEY (or wire your provider of choice).
#   3. Pin the coding-agent action to a specific SHA you have vetted.
#   4. Rename this file to `feedback-remediation-pr.yml`.
#   5. Trigger manually (workflow_dispatch) with a ticket key; keep it dispatch-
#      only until you trust it — do NOT add a `schedule:` without a review gate.
#
# Attribution: this repo commits under the maintainer identity only. The step
# below sets git identity accordingly and the PR body must NOT add assistant
# attribution — keep it consistent with the repo's authoring policy.

name: feedback-remediation-pr

on:
  workflow_dispatch:
    inputs:
      ticket:
        description: "Work-item ticket key to draft a fix for (e.g. VITL-123)"
        required: true
      brief:
        description: "Optional extra context / acceptance criteria"
        required: false

concurrency:
  group: feedback-remediation-pr-${{ github.event.inputs.ticket }}
  cancel-in-progress: false

permissions:
  contents: write
  pull-requests: write

jobs:
  draft-fix:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Configure git identity (maintainer only — no assistant attribution)
        run: |
          git config user.name  "JongoDB"
          git config user.email "198221045+JongoDB@users.noreply.github.com"
          git checkout -b "auto-fix/${{ github.event.inputs.ticket }}"

      # ── Coding agent step (pin to a vetted SHA before enabling) ──────────────
      # Replace with your chosen coding-agent action. It should: read the ticket,
      # implement a focused change, run the repo's checks (tsc/lint/test), and
      # STOP at a committed branch. Do NOT let it push to main or open a
      # non-draft PR.
      #
      # - name: Draft the fix
      #   uses: <your-vetted-coding-agent-action>@<sha>
      #   with:
      #     anthropic_api_key: ${{ secrets.ANTHROPIC_API_KEY }}
      #     prompt: |
      #       Implement ${{ github.event.inputs.ticket }}. ${{ github.event.inputs.brief }}
      #       Run `npm run typecheck && npm run lint && npm test` before finishing.
      #       Commit to the current branch only. Do not merge, deploy, or push to main.

      - name: Open a DRAFT pull request
        env:
          GH_TOKEN: ${{ github.token }}
          TICKET: ${{ github.event.inputs.ticket }}
        run: |
          if git diff --quiet origin/main -- .; then
            echo "::notice::No changes were produced for $TICKET — nothing to open."
            exit 0
          fi
          git push -u origin "auto-fix/$TICKET"
          gh pr create --draft \
            --base main --head "auto-fix/$TICKET" \
            --title "auto-fix: $TICKET (agent draft — needs review)" \
            --body "Auto-drafted from feedback ticket **$TICKET**. This is a DRAFT for human review; it has not been verified beyond CI. Do not merge without review."
